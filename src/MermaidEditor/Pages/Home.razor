@page "/"
@using MermaidEditor.Models
@using MermaidEditor.Services
@inject MermaidJsInterop MermaidInterop

<PageTitle>Mermaid Editor</PageTitle>

<div class="editor-container canvas-background sketch-font w-100 h-100 position-relative">

    <!-- Sleek Floating Toolbar -->
    <div class="floating-toolbar">
        <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="AddNode" title="Add Node" />
        <MudIconButton Icon="@Icons.Material.Filled.Clear" Color="Color.Error" OnClick="ClearGraph" title="Clear Canvas" />
        <div style="width: 1px; height: 24px; background-color: var(--mud-palette-divider); margin: 0 8px;"></div>
        <MudIconButton Icon="@Icons.Material.Filled.Download" Color="Color.Info" OnClick="ToggleExportDrawer" title="Export" />
        <div style="width: 1px; height: 24px; background-color: var(--mud-palette-divider); margin: 0 8px;"></div>
        <MudTooltip Text="Click and drag to move. Shift+Drag to connect. Double-click to edit text.">
            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" Class="mx-2" />
        </MudTooltip>
    </div>

    @if (selectedEdge != null)
    {
        <div class="floating-toolbar" style="top: 5rem;">
            <MudIconButton Icon="@Icons.Material.Filled.HorizontalRule" Color="@(selectedEdge.LineStyle == EdgeLineStyle.Solid ? Color.Primary : Color.Default)" OnClick="@(() => SetEdgeStyle(selectedEdge, EdgeLineStyle.Solid))" title="Solid Line" />
            <MudIconButton Icon="@Icons.Material.Filled.MoreHoriz" Color="@(selectedEdge.LineStyle == EdgeLineStyle.Dashed ? Color.Primary : Color.Default)" OnClick="@(() => SetEdgeStyle(selectedEdge, EdgeLineStyle.Dashed))" title="Dashed Line" />
            <MudIconButton Icon="@Icons.Material.Filled.LensBlur" Color="@(selectedEdge.LineStyle == EdgeLineStyle.Dotted ? Color.Primary : Color.Default)" OnClick="@(() => SetEdgeStyle(selectedEdge, EdgeLineStyle.Dotted))" title="Dotted Line" />
            <div style="width: 1px; height: 24px; background-color: var(--mud-palette-divider); margin: 0 8px;"></div>
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => DeleteEdge(selectedEdge))" title="Delete Edge" />
        </div>
    }

    <!-- Full Screen Canvas -->
    <svg class="graph-canvas w-100 h-100"
         style="cursor: crosshair;"
         @onmousemove="OnMouseMove"
         @onmouseup="OnMouseUp"
         @onmouseleave="OnMouseUp">

        <!-- Render edges -->
        @foreach (var edge in graph.Edges)
        {
            var source = graph.Nodes.FirstOrDefault(n => n.Id == edge.SourceNodeId);
            var target = graph.Nodes.FirstOrDefault(n => n.Id == edge.TargetNodeId);
            if (source != null && target != null)
            {
                var isSelected = selectedEdge == edge;
                var dashArray = edge.LineStyle switch
                {
                    EdgeLineStyle.Dashed => "8,8",
                    EdgeLineStyle.Dotted => "3,6",
                    _ => "none"
                };

                // Create a slightly curved path for a sketchy look
                var dx = target.X - source.X;
                var dy = target.Y - source.Y;
                var cx = source.X + dx / 2 + (dy * 0.1); // slight offset perpendicular to line
                var cy = source.Y + dy / 2 - (dx * 0.1);
                var pathD = $"M {source.X} {source.Y} Q {cx} {cy} {target.X} {target.Y}";

                <g style="cursor: pointer;" @onclick="@(e => OnEdgeClick(edge))" @onclick:stopPropagation="true">
                    <!-- Invisible thick path for easier clicking -->
                    <path d="@pathD" stroke="transparent" stroke-width="20" fill="none" />
                    <!-- Visible path -->
                    <path d="@pathD"
                          stroke="@(isSelected ? "var(--mud-palette-primary)" : "var(--mud-palette-text-primary)")"
                          stroke-width="@(isSelected ? "4" : "3")"
                          stroke-dasharray="@dashArray"
                          fill="none"
                          marker-end="url(#arrowhead@(isSelected ? "-selected" : ""))" />
                </g>
            }
        }

        <!-- Render active connection line if drawing -->
        @if (isConnecting && activeSourceNode != null)
        {
            var dx = mouseX - activeSourceNode.X;
            var dy = mouseY - activeSourceNode.Y;
            var cx = activeSourceNode.X + dx / 2 + (dy * 0.1);
            var cy = activeSourceNode.Y + dy / 2 - (dx * 0.1);
            var pathD = $"M {activeSourceNode.X} {activeSourceNode.Y} Q {cx} {cy} {mouseX} {mouseY}";

            <path d="@pathD"
                  stroke="var(--mud-palette-primary)" stroke-width="3" stroke-dasharray="8,8" fill="none" />
        }

        <!-- Render nodes -->
        @foreach (var node in graph.Nodes)
        {
            <g transform="translate(@node.X, @node.Y)"
               @onmousedown="@(e => OnNodeMouseDown(e, node))"
               @onmouseup="@(e => OnNodeMouseUp(e, node))"
               @ondblclick="@(() => EditNode(node))"
               class="graph-node" style="cursor: grab;">
                <rect x="-60" y="-30" width="120" height="60" rx="10" ry="10"
                      fill="@(node == activeSourceNode ? "var(--mud-palette-primary-lighten)" : "var(--mud-palette-surface)")"
                      stroke="var(--mud-palette-text-primary)" stroke-width="3" />

                @if (editingNodeId != node.Id)
                {
                    <svg:text text-anchor="middle" dy=".3em" class="sketch-font" font-size="20" fill="var(--mud-palette-text-primary)">@node.Label</svg:text>
                }
                else
                {
                    <foreignObject x="-55" y="-20" width="110" height="40" @onmousedown:stopPropagation="true" @ondblclick:stopPropagation="true">
                        <div xmlns="http://www.w3.org/1999/xhtml" style="width: 100%; height: 100%;">
                            <input id="node-editor-@node.Id"
                                   type="text"
                                   class="inline-editor-input"
                                   @bind="editingNodeText"
                                   @bind:event="oninput"
                                   @onblur="CommitNodeEdit"
                                   @onkeydown="OnEditorKeyDown" />
                        </div>
                    </foreignObject>
                }
            </g>
        }

        <defs>
            <!-- Hand-drawn style arrowhead (stroke instead of filled polygon) -->
            <marker id="arrowhead" markerWidth="10" markerHeight="10" refX="9" refY="5" orient="auto">
                <path d="M 0 0 L 10 5 L 0 10 M 10 5 L 4 5" stroke="var(--mud-palette-text-primary)" stroke-width="2" fill="none" stroke-linejoin="round" stroke-linecap="round" />
            </marker>
            <marker id="arrowhead-selected" markerWidth="10" markerHeight="10" refX="9" refY="5" orient="auto">
                <path d="M 0 0 L 10 5 L 0 10 M 10 5 L 4 5" stroke="var(--mud-palette-primary)" stroke-width="2" fill="none" stroke-linejoin="round" stroke-linecap="round" />
            </marker>
        </defs>
    </svg>

    <!-- Export Drawer -->
    <MudDrawer @bind-Open="_exportDrawerOpen" Anchor="Anchor.End" Elevation="1" Variant="@DrawerVariant.Temporary" Width="450px" Class="p-8">
        <MudDrawerHeader Class="px-0 pt-0">
            <MudText Typo="Typo.h5">Export Diagram</MudText>
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="ToggleExportDrawer" />
        </MudDrawerHeader>

        <MudText Typo="Typo.subtitle2" Class="mb-2">Mermaid Preview</MudText>
        <MudPaper Elevation="0" Class="p-4 mb-6 border-solid mud-border-lines-default rounded" Style="min-height: 200px; background-color: var(--mud-palette-surface); overflow: auto;">
            <div id="mermaid-preview" class="mermaid-render-area w-100 h-100"></div>
        </MudPaper>

        <MudText Typo="Typo.subtitle2" Class="mb-2">Mermaid Source</MudText>
        <MudPaper Elevation="0" Class="p-4 mb-6 border-solid mud-border-lines-default rounded" Style="background-color: var(--mud-palette-background-grey); position: relative; font-family: monospace;">
            <pre style="margin: 0; white-space: pre-wrap; word-wrap: break-word; color: var(--mud-palette-text-primary);" id="mermaid-source-code"><code>@mermaidCode</code></pre>
        </MudPaper>

        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ContentCopy" OnClick="CopyMermaidCodeToClipboard" FullWidth="true">Copy Code</MudButton>
    </MudDrawer>
</div>

<style>
    .graph-node:active {
        cursor: grabbing !important;
    }
</style>

@code {
    private Graph graph = new Graph();
    private string mermaidCode = "graph TD;";

    // State variables for interactions
    private MermaidEditor.Models.Edge? selectedEdge;
    private int nodeCounter = 1;
    private Node? draggingNode;
    private double dragOffsetX;
    private double dragOffsetY;
    private Node? activeSourceNode;
    private bool isConnecting;
    private double mouseX;
    private double mouseY;

    // Export Drawer State
    private bool _exportDrawerOpen = false;

    // Inline Editing State
    private string? editingNodeId;
    private string editingNodeText = string.Empty;

    private void ToggleExportDrawer()
    {
        _exportDrawerOpen = !_exportDrawerOpen;
    }

    private async Task CopyMermaidCodeToClipboard()
    {
        await MermaidInterop.CopyToClipboardAsync(mermaidCode);
    }

    private async Task EditNode(Node node)
    {
        editingNodeId = node.Id;
        editingNodeText = node.Label;

        // Wait for render so the input element exists
        await Task.Delay(50);
        await MermaidInterop.FocusElementAsync($"node-editor-{node.Id}");
    }

    private async Task CommitNodeEdit()
    {
        if (editingNodeId != null)
        {
            var node = graph.Nodes.FirstOrDefault(n => n.Id == editingNodeId);
            if (node != null)
            {
                node.Label = editingNodeText;
                await UpdateMermaidPreviewAsync();
            }
            editingNodeId = null;
        }
    }

    private async Task OnEditorKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == "Escape")
        {
            await CommitNodeEdit();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // Add a default node to start
        await AddNode();
        // UpdateMermaidPreviewAsync is called inside AddNode
    }

    private async Task AddNode()
    {
        var id = $"Node{nodeCounter}";
        graph.Nodes.Add(new Node
        {
            Id = id,
            Label = $"Node {nodeCounter}",
            X = 100 + (nodeCounter * 20 % 200),
            Y = 100 + (nodeCounter * 20 % 200)
        });
        nodeCounter++;
        await UpdateMermaidPreviewAsync();
    }

    private async Task ClearGraph()
    {
        graph = new Graph();
        nodeCounter = 1;
        await UpdateMermaidPreviewAsync();
    }

    private void OnNodeMouseDown(MouseEventArgs e, Node node)
    {
        if (e.ShiftKey)
        {
            // Start connecting
            isConnecting = true;
            activeSourceNode = node;
            mouseX = node.X;
            mouseY = node.Y;
        }
        else
        {
            // Start dragging
            draggingNode = node;
            dragOffsetX = e.ClientX - node.X;
            dragOffsetY = e.ClientY - node.Y;
        }
    }

    private async Task OnNodeMouseUp(MouseEventArgs e, Node targetNode)
    {
        if (isConnecting && activeSourceNode != null && activeSourceNode != targetNode)
        {
            // Check if edge already exists
            bool edgeExists = graph.Edges.Any(ed => ed.SourceNodeId == activeSourceNode.Id && ed.TargetNodeId == targetNode.Id);
            if (!edgeExists)
            {
                graph.Edges.Add(new MermaidEditor.Models.Edge
                {
                    Id = Guid.NewGuid().ToString(),
                    SourceNodeId = activeSourceNode.Id,
                    TargetNodeId = targetNode.Id,
                    Label = ""
                });
                await UpdateMermaidPreviewAsync();
            }
        }

        // Reset state
        isConnecting = false;
        activeSourceNode = null;
        draggingNode = null;
    }

    private void OnMouseMove(MouseEventArgs e)
    {
        if (draggingNode != null)
        {
            draggingNode.X = e.ClientX - dragOffsetX;
            draggingNode.Y = e.ClientY - dragOffsetY;
        }
        else if (isConnecting)
        {
            mouseX = e.ClientX;
            mouseY = e.ClientY;
        }
    }

    private void OnEdgeClick(MermaidEditor.Models.Edge edge)
    {
        selectedEdge = edge;
    }

    private async Task SetEdgeStyle(MermaidEditor.Models.Edge edge, EdgeLineStyle style)
    {
        edge.LineStyle = style;
        await UpdateMermaidPreviewAsync();
    }

    private async Task DeleteEdge(MermaidEditor.Models.Edge edge)
    {
        graph.Edges.Remove(edge);
        selectedEdge = null;
        await UpdateMermaidPreviewAsync();
    }

    private async Task OnMouseUp(MouseEventArgs e)
    {
        if (draggingNode != null)
        {
            draggingNode = null;
            await UpdateMermaidPreviewAsync();
        }

        if (isConnecting)
        {
            isConnecting = false;
            activeSourceNode = null;
        }

        // Deselect edge if clicking on empty space (not dragging or connecting)
        if (selectedEdge != null && !isConnecting && draggingNode == null)
        {
            // If the mouse up event propagates here, it means we clicked on the canvas
            // The edge click stops propagation.
            selectedEdge = null;
        }
    }

    private async Task UpdateMermaidPreviewAsync()
    {
        mermaidCode = MermaidSerializer.Serialize(graph);
        await MermaidInterop.RenderMermaidAsync("mermaid-preview", mermaidCode);
    }
}
