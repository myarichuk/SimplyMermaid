@code {
    private Graph graph = new Graph();
    private string mermaidCode = "graph TD;";
    private string mermaidImportCode = "graph TD;";

    // State variables for interactions
    private CommandManager commandManager = new CommandManager();
    private string? _previousGraphState;

    private async Task OnDiagramTypeChanged(DiagramType newType)
    {
        if (graph.DiagramType != newType)
        {
            if (graph.Nodes.Count > 0 || graph.Edges.Count > 0)
            {
                bool confirmed = await JS.InvokeAsync<bool>("confirm", "Switching diagram types will clear your current graph. Continue?");
                if (!confirmed)
                {
                    return;
                }
            }

            CaptureState();
            graph = new Graph { DiagramType = newType };
            nodeCounter = 1;
            selectedNode = null;
            selectedEdge = null;
            selectedNodes.Clear();
            selectedEdges.Clear();
            await UpdateMermaidPreviewAsync();
            CommitState();
        }
    }

    private void CaptureState()
    {
        _previousGraphState = System.Text.Json.JsonSerializer.Serialize(graph);
    }

    private void CommitState()
    {
        if (_previousGraphState != null)
        {
            var currentState = System.Text.Json.JsonSerializer.Serialize(graph);
            if (_previousGraphState != currentState)
            {
                var command = new SnapshotCommand(graph, _previousGraphState, currentState, async () =>
                {
                    selectedNode = null;
                    selectedEdge = null;
                    selectedNodes.Clear();
                    selectedEdges.Clear();
                    await UpdateMermaidPreviewAsync();
                    StateHasChanged();
                });
                commandManager.ExecuteCommand(command);
            }
            _previousGraphState = null;
        }
    }

    private void Undo()
    {
        commandManager.Undo();
    }

    private void Redo()
    {
        commandManager.Redo();
    }

    // Zoom & Pan State
    private double zoom = 1.0;
    private double panX = 0;
    private double panY = 0;
    private bool isPanning = false;
    private double panStartMouseX;
    private double panStartMouseY;
    private double panStartX;
    private double panStartY;

    private async Task DownloadJson()
    {
        var json = System.Text.Json.JsonSerializer.Serialize(graph, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        await MermaidInterop.DownloadTextAsync("diagram.json", json);
    }

    private async Task DownloadMarkdown()
    {
        await MermaidInterop.DownloadTextAsync("diagram.md", mermaidCode);
    }

    private async Task DownloadPng()
    {
        await MermaidInterop.DownloadSvgAsPngAsync("pretty-chart", "diagram.png");
    }

    private async Task DownloadSelectedJson()
    {
        var tempGraph = new Graph { DiagramType = graph.DiagramType };
        tempGraph.Nodes.AddRange(selectedNodes);
        tempGraph.Edges.AddRange(selectedEdges);
        var json = System.Text.Json.JsonSerializer.Serialize(tempGraph, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        await MermaidInterop.DownloadTextAsync("diagram_selected.json", json);
    }

    private async Task DownloadSelectedMarkdown()
    {
        var mermaidSelected = MermaidSerializer.SerializeSelection(graph, selectedNodes, selectedEdges);
        await MermaidInterop.DownloadTextAsync("diagram_selected.md", mermaidSelected);
    }

    private void OnSvgMouseDown(MouseEventArgs e)
    {
        _ = containerRef.FocusAsync();
        selectedNode = null;
        selectedEdge = null;

        if (e.Button == 0 && !e.ShiftKey && draggingNode == null && !isConnecting)
        {
             HandleCanvasDown(e.ClientX, e.ClientY, e.CtrlKey || e.MetaKey || e.ShiftKey);
        }
        else if (e.Button == 1) // Middle mouse
        {
             HandleCanvasDown(e.ClientX, e.ClientY, false, true);
        }
    }

    private void HandleCanvasDown(double clientX, double clientY, bool keepSelection = false, bool isMiddleClick = false)
    {
        if (isMiddleClick)
        {
             isPanning = true;
             panStartMouseX = clientX;
             panStartMouseY = clientY;
             panStartX = panX;
             panStartY = panY;
        }
        else
        {
             isLassoing = true;
             if (!keepSelection)
             {
                 selectedNodes.Clear();
                 selectedEdges.Clear();
             }
             lassoStartX = (clientX - panX) / zoom;
             lassoStartY = (clientY - panY) / zoom;
             lassoCurrentX = lassoStartX;
             lassoCurrentY = lassoStartY;
        }
    }

    // Fix for Issue 2: TOUCH / MOBILE
    // Added touch-specific event handlers mapping directly to pointer logic
    private void OnSvgTouchStart(TouchEventArgs e)
    {
        _ = containerRef.FocusAsync();
        if (e.TargetTouches != null && e.TargetTouches.Length > 0 && draggingNode == null && !isConnecting)
        {
            var touch = e.TargetTouches[0];
            HandleCanvasDown(touch.ClientX, touch.ClientY);
        }
    }

    private void OnSvgTouchMove(TouchEventArgs e)
    {
        if (e.TargetTouches != null && e.TargetTouches.Length > 0)
        {
            var touch = e.TargetTouches[0];
            HandlePointerMove(touch.ClientX, touch.ClientY);
        }
    }

    private async Task OnSvgTouchEnd(TouchEventArgs e)
    {
        await HandlePointerUp();
    }

    private void OnWheel(WheelEventArgs e)
    {
        double zoomFactor = 1.1;
        double oldZoom = zoom;

        if (e.DeltaY < 0) zoom *= zoomFactor;
        else if (e.DeltaY > 0) zoom /= zoomFactor;

        if (zoom < 0.1) zoom = 0.1;
        if (zoom > 5.0) zoom = 5.0;

        double mouseX = e.ClientX;
        double mouseY = e.ClientY;

        panX = mouseX - (mouseX - panX) * (zoom / oldZoom);
        panY = mouseY - (mouseY - panY) * (zoom / oldZoom);
    }

    private void ZoomIn()
    {
        double oldZoom = zoom;
        zoom *= 1.2;
        if (zoom > 5.0) zoom = 5.0;
        panX = panX * (zoom / oldZoom);
        panY = panY * (zoom / oldZoom);
    }

    private void ZoomOut()
    {
        double oldZoom = zoom;
        zoom /= 1.2;
        if (zoom < 0.1) zoom = 0.1;
        panX = panX * (zoom / oldZoom);
        panY = panY * (zoom / oldZoom);
    }

    private void ResetZoomPan()
    {
        zoom = 1.0;
        panX = 0;
        panY = 0;
    }

    private MermaidEditor.Models.Edge? selectedEdge;
    private Node? selectedNode;
    private double contextMenuX;
    private double contextMenuY;
    private ElementReference containerRef;
    private int nodeCounter = 1;
    private Node? draggingNode;
    private bool isLassoing = false;
    private double lassoStartX;
    private double lassoStartY;
    private double lassoCurrentX;
    private double lassoCurrentY;
    private HashSet<Node> selectedNodes = new HashSet<Node>();
    private HashSet<MermaidEditor.Models.Edge> selectedEdges = new HashSet<MermaidEditor.Models.Edge>();
    private Dictionary<Node, (double offsetX, double offsetY)> dragOffsets = new();
    private double dragOffsetX;
    private double dragOffsetY;
    private Node? activeSourceNode;
    private bool isConnecting;
    private double mouseX;
    private double mouseY;
    private Node? resizingNode;
    private double resizeStartWidth;
    private double resizeStartHeight;
    private double resizeStartMouseX;
    private double resizeStartMouseY;

    // Export Drawer State
    private bool _exportDrawerOpen = false;
    private bool _importDrawerOpen = false;

    // Inline Editing State
    private string? editingNodeId;
    private string editingNodeText = string.Empty;
    private string? editingEdgeId;
    private string editingEdgeText = string.Empty;

    private void ToggleExportDrawer()
    {
        _exportDrawerOpen = !_exportDrawerOpen;
    }

    private void ToggleImportDrawer()
    {
        _importDrawerOpen = !_importDrawerOpen;
    }

    private async Task UploadJson(IBrowserFile file)
    {
        if (file == null) return;
        try
        {
            using var stream = file.OpenReadStream();
            var importedGraph = await System.Text.Json.JsonSerializer.DeserializeAsync<Graph>(stream);
            if (importedGraph != null)
            {
                CaptureState();
                graph = importedGraph;
                selectedNode = null;
                selectedEdge = null;
                selectedNodes.Clear();
                selectedEdges.Clear();

                nodeCounter = 1;
                foreach (var node in graph.Nodes)
                {
                    if (node.Id.StartsWith("Node") && int.TryParse(node.Id.Substring(4), out int idNum))
                    {
                        if (idNum >= nodeCounter) nodeCounter = idNum + 1;
                    }
                }
                await UpdateMermaidPreviewAsync();
                CommitState();
                _importDrawerOpen = false;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"JSON import failed: {ex.Message}");
        }
    }

    private async Task CopyMermaidCodeToClipboard()
    {
        await MermaidInterop.CopyToClipboardAsync(mermaidCode);
    }

    private async Task EditNode(Node node)
    {
        editingNodeId = node.Id;
        editingNodeText = node.Label;

        // Wait for render so the input element exists
        await Task.Delay(50);
        await MermaidInterop.FocusElementAsync($"node-editor-{node.Id}");
    }

    private async Task CommitNodeEdit()
    {
        if (editingNodeId != null)
        {
            CaptureState();
            var node = graph.Nodes.FirstOrDefault(n => n.Id == editingNodeId);
            if (node != null)
            {
                node.Label = editingNodeText;

                // Adjust node width based on label length to ensure text fits
                // Rough estimate: each character takes ~10px width
                double estimatedTextWidth = Math.Max(node.Label.Length * 10 + 40, node.Type == NodeType.Circle ? 80 : 120);
                if (node.Width < estimatedTextWidth)
                {
                    node.Width = estimatedTextWidth;
                    if (node.Type == NodeType.Circle)
                    {
                        node.Height = estimatedTextWidth;
                    }
                }

                // Apply a simple repulsion algorithm to separate overlapping nodes
                ResolveOverlaps();

                await UpdateMermaidPreviewAsync();
            }
            editingNodeId = null;
            CommitState();
        }
    }

    private void ResolveOverlaps()
    {
        bool moved;
        int iterations = 0;
        int maxIterations = 50;
        do
        {
            moved = false;
            for (int i = 0; i < graph.Nodes.Count; i++)
            {
                for (int j = i + 1; j < graph.Nodes.Count; j++)
                {
                    var n1 = graph.Nodes[i];
                    var n2 = graph.Nodes[j];

                    double dx = n2.X - n1.X;
                    double dy = n2.Y - n1.Y;
                    double dist = Math.Sqrt(dx * dx + dy * dy);

                    // Estimate bounding radius (approximate based on diagonal)
                    double r1 = Math.Sqrt((n1.Width/2)*(n1.Width/2) + (n1.Height/2)*(n1.Height/2));
                    double r2 = Math.Sqrt((n2.Width/2)*(n2.Width/2) + (n2.Height/2)*(n2.Height/2));
                    double minD = r1 + r2 + 20; // 20px padding

                    if (dist < minD)
                    {
                        moved = true;
                        // Avoid division by zero
                        if (dist == 0)
                        {
                            dx = 1;
                            dy = 0;
                            dist = 1;
                        }

                        double pushDist = (minD - dist) / 2;
                        double pushX = (dx / dist) * pushDist;
                        double pushY = (dy / dist) * pushDist;

                        n1.X -= pushX;
                        n1.Y -= pushY;
                        n2.X += pushX;
                        n2.Y += pushY;
                    }
                }
            }
            iterations++;
        } while (moved && iterations < maxIterations);
    }

    private async Task OnEditorKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == "Escape")
        {
            await CommitNodeEdit();
            await CommitEdgeEdit();
        }
    }

    private async Task EditEdge(MermaidEditor.Models.Edge edge)
    {
        editingEdgeId = edge.Id;
        editingEdgeText = edge.Label;

        await Task.Delay(50);
        await MermaidInterop.FocusElementAsync($"edge-editor-{edge.Id}");
    }

    private async Task CommitEdgeEdit()
    {
        if (editingEdgeId != null)
        {
            CaptureState();
            var edge = graph.Edges.FirstOrDefault(e => e.Id == editingEdgeId);
            if (edge != null)
            {
                edge.Label = editingEdgeText;
                await UpdateMermaidPreviewAsync();
            }
            editingEdgeId = null;
            CommitState();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var savedGraph = await LocalStorage.GetItemAsync<Graph>("mermaid_graph");
        if (savedGraph != null && savedGraph.Nodes.Any())
        {
            graph = savedGraph;
            foreach (var node in graph.Nodes)
            {
                if (node.Id.StartsWith("Node") && int.TryParse(node.Id.Substring(4), out int idNum))
                {
                    if (idNum >= nodeCounter) nodeCounter = idNum + 1;
                }
            }
            await UpdateMermaidPreviewAsync();
        }
        else
        {
            await AddNode(NodeType.Rectangle);
        }
    }

    private NodeType? draggedShapeType;

    private void OnDragStartShape(NodeType type)
    {
        draggedShapeType = type;
    }

    private async Task OnCanvasDrop(DragEventArgs e)
    {
        if (draggedShapeType.HasValue)
        {
            CaptureState();
            var id = $"Node{nodeCounter}";
            double localX = (e.ClientX - panX) / zoom;
            double localY = (e.ClientY - panY) / zoom;

            graph.Nodes.Add(new Node
            {
                Id = id,
                Label = $"Node {nodeCounter}",
                X = localX,
                Y = localY,
                Type = draggedShapeType.Value,
                Width = draggedShapeType.Value == NodeType.Circle ? 80 : 120,
                Height = draggedShapeType.Value == NodeType.Circle ? 80 : 60
            });
            nodeCounter++;
            draggedShapeType = null;
            await UpdateMermaidPreviewAsync();
            CommitState();
        }
    }

    private async Task AddNode(NodeType type)
    {
        CaptureState();
        var id = $"Node{nodeCounter}";
        // Add to roughly center of view
        double centerX = (400 - panX) / zoom;
        double centerY = (300 - panY) / zoom;
        // Default slightly offset if multiple created
        double offsetX = (nodeCounter * 20 % 100);
        double offsetY = (nodeCounter * 20 % 100);

        graph.Nodes.Add(new Node
        {
            Id = id,
            Label = $"Node {nodeCounter}",
            X = centerX + offsetX,
            Y = centerY + offsetY,
            Type = type,
            Width = type == NodeType.Circle ? 80 : 120,
            Height = type == NodeType.Circle ? 80 : 60
        });
        nodeCounter++;
        await UpdateMermaidPreviewAsync();
        CommitState();
    }

    private async Task ClearGraph()
    {
        CaptureState();
        graph = new Graph();
        nodeCounter = 1;
        await UpdateMermaidPreviewAsync();
        CommitState();
    }

    private void OnNodeMouseDown(MouseEventArgs e, Node node)
    {
        _ = containerRef.FocusAsync();
        if (e.Button == 1 || e.Button == 2) return; // Ignore middle and right clicks for dragging
        HandleNodeDown(e.ClientX, e.ClientY, e.ShiftKey, e.CtrlKey || e.MetaKey, node);
    }

    private void OnNodeTouchStart(TouchEventArgs e, Node node)
    {
        _ = containerRef.FocusAsync();
        if (e.TargetTouches != null && e.TargetTouches.Length > 0)
        {
            var touch = e.TargetTouches[0];
            // We'll treat long-presses (where we wouldn't normally get shift key) as connecting sometimes,
            // but the prompt mentions "Shift-drag edges" - some virtual keyboards or desktop touch handles shift.
            HandleNodeDown(touch.ClientX, touch.ClientY, e.ShiftKey, false, node);
        }
    }

    private void HandleNodeDown(double clientX, double clientY, bool shiftKey, bool multiSelectKey, Node node)
    {
        if (shiftKey)
        {
            // Start connecting
            isConnecting = true;
            activeSourceNode = node;
            mouseX = node.X;
            mouseY = node.Y;
        }
        else
        {
            // Start dragging
            CaptureState(); // Capture state before dragging starts
            draggingNode = node;
            double localX = (clientX - panX) / zoom;
            double localY = (clientY - panY) / zoom;
            dragOffsetX = localX - node.X;
            dragOffsetY = localY - node.Y;

            if (multiSelectKey)
            {
                if (selectedNodes.Contains(node))
                    selectedNodes.Remove(node);
                else
                    selectedNodes.Add(node);
            }
            else
            {
                if (!selectedNodes.Contains(node))
                {
                    selectedNodes.Clear();
                    selectedNodes.Add(node);
                }
            }

            dragOffsets.Clear();
            foreach (var n in selectedNodes)
            {
                dragOffsets[n] = (localX - n.X, localY - n.Y);
            }
        }
    }

    private async Task OnNodeTouchEnd(TouchEventArgs e, Node node)
    {
        await HandleNodeUp(node);
    }

    private async Task OnNodeMouseUp(MouseEventArgs e, Node targetNode)
    {
        await HandleNodeUp(targetNode);
    }

    private async Task HandleNodeUp(Node targetNode)
    {
        if (isConnecting && activeSourceNode != null && activeSourceNode != targetNode)
        {
            // Check if edge already exists
            bool edgeExists = graph.Edges.Any(ed => ed.SourceNodeId == activeSourceNode.Id && ed.TargetNodeId == targetNode.Id);
            if (!edgeExists)
            {
                CaptureState();
                graph.Edges.Add(new MermaidEditor.Models.Edge
                {
                    Id = Guid.NewGuid().ToString(),
                    SourceNodeId = activeSourceNode.Id,
                    TargetNodeId = targetNode.Id,
                    Label = ""
                });
                await UpdateMermaidPreviewAsync();
                CommitState();
            }
        }

        // Reset state
        isConnecting = false;
        activeSourceNode = null;
        if (draggingNode != null)
        {
            draggingNode = null;
            CommitState();
        }
    }

    private void OnResizeMouseDown(MouseEventArgs e, Node node)
    {
        HandleResizeDown(e.ClientX, e.ClientY, node);
    }

    private void OnResizeTouchStart(TouchEventArgs e, Node node)
    {
        if (e.TargetTouches != null && e.TargetTouches.Length > 0)
        {
            var touch = e.TargetTouches[0];
            HandleResizeDown(touch.ClientX, touch.ClientY, node);
        }
    }

    private void HandleResizeDown(double clientX, double clientY, Node node)
    {
        resizingNode = node;
        resizeStartWidth = node.Width;
        resizeStartHeight = node.Height;
        resizeStartMouseX = clientX;
        resizeStartMouseY = clientY;
    }

    private void OnSvgContextMenu(MouseEventArgs e)
    {
        selectedNode = null;
        selectedEdge = null;
    }

    private void OnNodeContextMenu(MouseEventArgs e, Node node)
    {
        selectedNode = node;
        selectedEdge = null;
        contextMenuX = e.ClientX;
        contextMenuY = e.ClientY;
    }

    private void OnEdgeTouchStart(TouchEventArgs e, MermaidEditor.Models.Edge edge)
    {
        if (e.TargetTouches != null && e.TargetTouches.Length > 0)
        {
            var touch = e.TargetTouches[0];
            selectedEdge = edge;
            selectedNode = null;
            contextMenuX = touch.ClientX;
            contextMenuY = touch.ClientY;
        }
    }

    private void OnEdgeContextMenu(MouseEventArgs e, MermaidEditor.Models.Edge edge)
    {
        if (e.ShiftKey)
        {
            if (selectedEdges.Contains(edge)) selectedEdges.Remove(edge);
            else selectedEdges.Add(edge);
        }
        else
        {
            selectedEdge = edge;
            if (!selectedEdges.Contains(edge))
            {
                selectedEdges.Clear();
                selectedEdges.Add(edge);
            }
        }
        selectedNode = null;
        contextMenuX = e.ClientX;
        contextMenuY = e.ClientY;
    }

    // Fix for Issue 1: PERFORMANCE
    // Before: Every PointerMove directly invoked C# -> Mermaid serialization -> JS rendering (heavy).
    // After: Debounce pointer movements (max ~60fps checking), pushing updates to a throttled QueueRender(false).
    private DateTime _lastMoveTime = DateTime.MinValue;

    private void OnMouseMove(MouseEventArgs e)
    {
        HandlePointerMove(e.ClientX, e.ClientY);
    }

    private void HandlePointerMove(double clientX, double clientY)
    {
        if (isLassoing)
        {
            lassoCurrentX = (clientX - panX) / zoom;
            lassoCurrentY = (clientY - panY) / zoom;
        }

        if (isPanning || isLassoing || resizingNode != null || draggingNode != null || isConnecting)
        {
            if (isPanning)
            {
                panX = panStartX + (clientX - panStartMouseX);
                panY = panStartY + (clientY - panStartMouseY);
            }
            else if (resizingNode != null)
            {
                double deltaX = (clientX - resizeStartMouseX) / zoom;
                double deltaY = (clientY - resizeStartMouseY) / zoom;

            double multiplierX = 2;
            double multiplierY = 2;

            if (resizingNode.Type == NodeType.Rhombus)
            {
                multiplierX = 4;
                multiplierY = 4;
            }
            else if (resizingNode.Type == NodeType.Circle)
            {
                multiplierX = 2.828427; // 2 / 0.707106
                multiplierY = 2.828427;
            }
            else if (resizingNode.Type == NodeType.Hexagon)
            {
                multiplierX = 3;
                multiplierY = 3;
            }

            // we're dragging from the handle, so modify width and height proportionally to ensure the center remains fixed
            double newWidth = resizeStartWidth + deltaX * multiplierX;
            double newHeight = resizeStartHeight + deltaY * multiplierY;

                if (resizingNode.Type == NodeType.Circle)
                {
                    // Maintain aspect ratio for circles
                    double size = Math.Max(40, Math.Max(newWidth, newHeight));
                    resizingNode.Width = size;
                    resizingNode.Height = size;
                }
                else
                {
                    if (newWidth >= 40) resizingNode.Width = newWidth;
                    if (newHeight >= 40) resizingNode.Height = newHeight;
                }
            }
            else if (draggingNode != null)
            {
                double localX = (clientX - panX) / zoom;
                double localY = (clientY - panY) / zoom;

                if (selectedNodes.Contains(draggingNode))
                {
                    foreach (var n in selectedNodes)
                    {
                        if (dragOffsets.TryGetValue(n, out var offset))
                        {
                            n.X = localX - offset.offsetX;
                            n.Y = localY - offset.offsetY;
                        }
                    }
                }
                else
                {
                    draggingNode.X = localX - dragOffsetX;
                    draggingNode.Y = localY - dragOffsetY;
                }
            }
            else if (isConnecting)
            {
                mouseX = (clientX - panX) / zoom;
                mouseY = (clientY - panY) / zoom;
            }

            var now = DateTime.UtcNow;
            if ((now - _lastMoveTime).TotalMilliseconds >= 16)
            {
                _lastMoveTime = now;
                // Queue a render (not immediate, so it can bundle rapid moves)
                _ = QueueRender(false);
            }
        }
    }

