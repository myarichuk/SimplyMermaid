@page "/"
@using MermaidEditor.Models
@using MermaidEditor.Services
@inject MermaidJsInterop MermaidInterop

<PageTitle>Mermaid Editor</PageTitle>

<MudPaper Elevation="0" Class="editor-container h-100 d-flex flex-column" Style="height: calc(100vh - 100px);">
    <MudToolBar Class="toolbar border-b border-solid mud-border-lines-default">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="AddNode" Class="mr-3">Add Node</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Clear" OnClick="ClearGraph">Clear</MudButton>
        <MudSpacer />
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-1 mb-n1" />
            Click and drag a node to move. Shift+Drag from one node to another to connect.
        </MudText>
    </MudToolBar>

    <MudGrid Spacing="0" Class="flex-grow-1 overflow-hidden m-0">
        <MudItem xs="12" md="6" Class="d-flex flex-column border-r border-solid mud-border-lines-default p-4" Style="height: 100%;">
            <MudText Typo="Typo.h6" Class="mb-3">Visual Canvas</MudText>
            <MudPaper Elevation="1" Class="flex-grow-1 d-flex overflow-hidden position-relative">
                <svg class="graph-canvas w-100 h-100"
                     style="background-color: var(--mud-palette-background-grey); cursor: crosshair;"
                     @onmousemove="OnMouseMove"
                     @onmouseup="OnMouseUp"
                     @onmouseleave="OnMouseUp">
                    <!-- Render edges -->
                    @foreach (var edge in graph.Edges)
                    {
                        var source = graph.Nodes.FirstOrDefault(n => n.Id == edge.SourceNodeId);
                        var target = graph.Nodes.FirstOrDefault(n => n.Id == edge.TargetNodeId);
                        if (source != null && target != null)
                        {
                            <line x1="@source.X" y1="@source.Y"
                                  x2="@target.X" y2="@target.Y"
                                  stroke="var(--mud-palette-text-secondary)" stroke-width="2" marker-end="url(#arrowhead)" />
                        }
                    }

                    <!-- Render active connection line if drawing -->
                    @if (isConnecting && activeSourceNode != null)
                    {
                        <line x1="@activeSourceNode.X" y1="@activeSourceNode.Y"
                              x2="@mouseX" y2="@mouseY"
                              stroke="var(--mud-palette-primary)" stroke-width="2" stroke-dasharray="5,5" />
                    }

                    <!-- Render nodes -->
                    @foreach (var node in graph.Nodes)
                    {
                        <g transform="translate(@node.X, @node.Y)"
                           @onmousedown="@(e => OnNodeMouseDown(e, node))"
                           @onmouseup="@(e => OnNodeMouseUp(e, node))"
                           class="graph-node" style="cursor: grab;">
                            <circle r="30" fill="@(node == activeSourceNode ? "var(--mud-palette-primary-lighten)" : "var(--mud-palette-surface)")"
                                    stroke="var(--mud-palette-primary)" stroke-width="2" />
                            <text text-anchor="middle" dy=".3em" font-family="Roboto, Arial" font-size="12" fill="var(--mud-palette-text-primary)">@node.Label</text>
                        </g>
                    }

                    <defs>
                        <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="35" refY="3.5" orient="auto">
                            <polygon points="0 0, 10 3.5, 0 7" fill="var(--mud-palette-text-secondary)" />
                        </marker>
                    </defs>
                </svg>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6" Class="d-flex flex-column p-4 overflow-y-auto" Style="height: 100%;">
            <MudText Typo="Typo.h6" Class="mb-3">Mermaid Preview</MudText>
            <MudPaper Elevation="1" Class="p-3 mb-4 flex-grow-1" Style="min-height: 300px; overflow: auto; background-color: var(--mud-palette-surface);">
                <div id="mermaid-preview" class="mermaid-render-area w-100 h-100"></div>
            </MudPaper>

            <MudText Typo="Typo.h6" Class="mb-3">Generated Mermaid Code</MudText>
            <MudPaper Elevation="0" Class="p-3 border-solid mud-border-lines-default" Style="background-color: var(--mud-palette-background-grey);">
                <pre style="margin: 0; color: var(--mud-palette-text-primary);"><code>@mermaidCode</code></pre>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudPaper>

<style>
    .graph-node:active {
        cursor: grabbing !important;
    }
</style>

@code {
    private Graph graph = new Graph();
    private string mermaidCode = "graph TD;";

    // State variables for interactions
    private int nodeCounter = 1;
    private Node? draggingNode;
    private Node? activeSourceNode;
    private bool isConnecting;
    private double mouseX;
    private double mouseY;

    protected override async Task OnInitializedAsync()
    {
        // Add a default node to start
        await AddNode();
        // UpdateMermaidPreviewAsync is called inside AddNode
    }

    private async Task AddNode()
    {
        var id = $"Node{nodeCounter}";
        graph.Nodes.Add(new Node
        {
            Id = id,
            Label = $"Node {nodeCounter}",
            X = 100 + (nodeCounter * 20 % 200),
            Y = 100 + (nodeCounter * 20 % 200)
        });
        nodeCounter++;
        await UpdateMermaidPreviewAsync();
    }

    private async Task ClearGraph()
    {
        graph = new Graph();
        nodeCounter = 1;
        await UpdateMermaidPreviewAsync();
    }

    private void OnNodeMouseDown(MouseEventArgs e, Node node)
    {
        if (e.ShiftKey)
        {
            // Start connecting
            isConnecting = true;
            activeSourceNode = node;
            mouseX = node.X;
            mouseY = node.Y;
        }
        else
        {
            // Start dragging
            draggingNode = node;
        }
    }

    private async Task OnNodeMouseUp(MouseEventArgs e, Node targetNode)
    {
        if (isConnecting && activeSourceNode != null && activeSourceNode != targetNode)
        {
            // Check if edge already exists
            bool edgeExists = graph.Edges.Any(ed => ed.SourceNodeId == activeSourceNode.Id && ed.TargetNodeId == targetNode.Id);
            if (!edgeExists)
            {
                graph.Edges.Add(new MermaidEditor.Models.Edge
                {
                    Id = Guid.NewGuid().ToString(),
                    SourceNodeId = activeSourceNode.Id,
                    TargetNodeId = targetNode.Id,
                    Label = ""
                });
                await UpdateMermaidPreviewAsync();
            }
        }

        // Reset state
        isConnecting = false;
        activeSourceNode = null;
        draggingNode = null;
    }

    private void OnMouseMove(MouseEventArgs e)
    {
        if (draggingNode != null)
        {
            // Simple drag logic (offset might need adjustment based on canvas position)
            draggingNode.X = e.OffsetX;
            draggingNode.Y = e.OffsetY;
        }
        else if (isConnecting)
        {
            mouseX = e.OffsetX;
            mouseY = e.OffsetY;
        }
    }

    private async Task OnMouseUp(MouseEventArgs e)
    {
        if (draggingNode != null)
        {
            draggingNode = null;
            await UpdateMermaidPreviewAsync();
        }

        if (isConnecting)
        {
            isConnecting = false;
            activeSourceNode = null;
        }
    }

    private async Task UpdateMermaidPreviewAsync()
    {
        mermaidCode = MermaidSerializer.Serialize(graph);
        await MermaidInterop.RenderMermaidAsync("mermaid-preview", mermaidCode);
    }
}
