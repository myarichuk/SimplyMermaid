@page "/"
@using MermaidEditor.Models
@using MermaidEditor.Services
@using Blazored.LocalStorage
@inject MermaidJsInterop MermaidInterop
@inject ILocalStorageService LocalStorage

<PageTitle>Mermaid Editor</PageTitle>

    <div class="editor-container canvas-background sketch-font w-100 h-100 position-relative" @onkeydown="OnKeyDown" tabindex="0" @ref="containerRef"
         @ondragover:preventDefault="true" @ondrop="OnCanvasDrop">

    <!-- Sleek Floating Toolbar -->
    <div class="floating-toolbar">
        <MudIconButton Icon="@Icons.Material.Filled.Clear" Color="Color.Error" OnClick="ClearGraph" title="Clear Canvas" />
        <div style="width: 1px; height: 24px; background-color: var(--mud-palette-divider); margin: 0 8px;"></div>
        <MudIconButton Icon="@Icons.Material.Filled.Remove" Color="Color.Default" OnClick="ZoomOut" title="Zoom Out" />
        <div style="width: 100px; display: flex; align-items: center;" class="mx-2">
            <MudSlider @bind-Value="zoom" Min="0.1" Max="5.0" Step="0.1" title="Zoom Slider" Size="Size.Small" Color="Color.Primary" />
        </div>
        <MudText Typo="Typo.body2" Class="mx-2" Style="min-width: 40px;">@(Math.Round(zoom * 100))%</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Default" OnClick="ZoomIn" title="Zoom In" />
        <MudIconButton Icon="@Icons.Material.Filled.FilterCenterFocus" Color="Color.Default" OnClick="ResetZoomPan" title="Reset View" />
        <div style="width: 1px; height: 24px; background-color: var(--mud-palette-divider); margin: 0 8px;"></div>
        <MudIconButton Icon="@Icons.Material.Filled.Download" Color="Color.Info" OnClick="ToggleExportDrawer" title="Export" />
        <div style="width: 1px; height: 24px; background-color: var(--mud-palette-divider); margin: 0 8px;"></div>
        <MudTooltip Text="Click and drag to move. Shift+Drag to connect. Double-click to edit text.">
            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" Class="mx-2" />
        </MudTooltip>
    </div>

    <!-- Left Toolbar for Nodes -->
    <div class="floating-toolbar-left">
        <div draggable="true" @ondragstart="@(e => OnDragStartShape(NodeType.Rectangle))" style="cursor: grab;">
            <MudIconButton OnClick="@(() => AddNode(NodeType.Rectangle))" title="Rectangle">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" style="pointer-events: none;"><rect x="3" y="6" width="18" height="12"></rect></svg>
            </MudIconButton>
        </div>
        <div draggable="true" @ondragstart="@(e => OnDragStartShape(NodeType.RoundedRectangle))" style="cursor: grab;">
            <MudIconButton OnClick="@(() => AddNode(NodeType.RoundedRectangle))" title="Rounded Rectangle">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" style="pointer-events: none;"><rect x="3" y="6" width="18" height="12" rx="4"></rect></svg>
            </MudIconButton>
        </div>
        <div draggable="true" @ondragstart="@(e => OnDragStartShape(NodeType.Stadium))" style="cursor: grab;">
            <MudIconButton OnClick="@(() => AddNode(NodeType.Stadium))" title="Stadium">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" style="pointer-events: none;"><rect x="3" y="6" width="18" height="12" rx="6"></rect></svg>
            </MudIconButton>
        </div>
        <div draggable="true" @ondragstart="@(e => OnDragStartShape(NodeType.Cylinder))" style="cursor: grab;">
            <MudIconButton OnClick="@(() => AddNode(NodeType.Cylinder))" title="Cylinder">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" style="pointer-events: none;"><path d="M4 8c0-2.2 3.6-4 8-4s8 1.8 8 4v8c0 2.2-3.6 4-8 4s-8-1.8-8-4V8z"></path><path d="M4 8c0 2.2 3.6 4 8 4s8-1.8 8-4"></path></svg>
            </MudIconButton>
        </div>
        <div draggable="true" @ondragstart="@(e => OnDragStartShape(NodeType.Circle))" style="cursor: grab;">
            <MudIconButton OnClick="@(() => AddNode(NodeType.Circle))" title="Circle">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" style="pointer-events: none;"><circle cx="12" cy="12" r="8"></circle></svg>
            </MudIconButton>
        </div>
        <div draggable="true" @ondragstart="@(e => OnDragStartShape(NodeType.Rhombus))" style="cursor: grab;">
            <MudIconButton OnClick="@(() => AddNode(NodeType.Rhombus))" title="Rhombus">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" style="pointer-events: none;"><polygon points="12 3 21 12 12 21 3 12 12 3"></polygon></svg>
            </MudIconButton>
        </div>
        <div draggable="true" @ondragstart="@(e => OnDragStartShape(NodeType.Hexagon))" style="cursor: grab;">
            <MudIconButton OnClick="@(() => AddNode(NodeType.Hexagon))" title="Hexagon">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" style="pointer-events: none;"><polygon points="12 2 21 7 21 17 12 22 3 17 3 7 12 2"></polygon></svg>
            </MudIconButton>
        </div>
    </div>

    @if (selectedEdge != null && editingEdgeId == null)
    {
        <div class="floating-toolbar" style="top: @(edgeClickY)px; left: @(edgeClickX)px; transform: translate(-50%, -100%); margin-top: -10px; z-index: 1000;" @onmousedown:stopPropagation="true">
            <MudIconButton Icon="@Icons.Material.Filled.HorizontalRule" Color="@(selectedEdge.LineStyle == EdgeLineStyle.Solid ? Color.Primary : Color.Default)" OnClick="@(() => SetEdgeStyle(selectedEdge, EdgeLineStyle.Solid))" title="Solid Line" />
            <MudIconButton Icon="@Icons.Material.Filled.MoreHoriz" Color="@(selectedEdge.LineStyle == EdgeLineStyle.Dashed ? Color.Primary : Color.Default)" OnClick="@(() => SetEdgeStyle(selectedEdge, EdgeLineStyle.Dashed))" title="Dashed Line" />
            <MudIconButton Icon="@Icons.Material.Filled.LensBlur" Color="@(selectedEdge.LineStyle == EdgeLineStyle.Dotted ? Color.Primary : Color.Default)" OnClick="@(() => SetEdgeStyle(selectedEdge, EdgeLineStyle.Dotted))" title="Dotted Line" />
            <div style="width: 1px; height: 24px; background-color: var(--mud-palette-divider); margin: 0 8px;"></div>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="@(() => EditEdge(selectedEdge))" title="Edit Label" />
            <div style="width: 1px; height: 24px; background-color: var(--mud-palette-divider); margin: 0 8px;"></div>
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => DeleteEdge(selectedEdge))" title="Delete Edge" />
        </div>
    }

    @if (selectedNode != null && editingNodeId == null)
    {
        <div class="floating-toolbar" style="top: @(nodeClickY)px; left: @(nodeClickX)px; transform: translate(-50%, -100%); margin-top: -10px; z-index: 1000;" @onmousedown:stopPropagation="true">
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="@(() => EditNode(selectedNode))" title="Edit Label" />
            <div style="width: 1px; height: 24px; background-color: var(--mud-palette-divider); margin: 0 8px;"></div>
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => DeleteNode(selectedNode))" title="Delete Node" />
        </div>
    }

    <!-- Full Screen Canvas -->
    <svg class="graph-canvas w-100 h-100"
         style="cursor: @(isPanning ? "grabbing" : "crosshair");"
         @onmousemove="OnMouseMove"
         @onmouseup="OnMouseUp"
         @onmouseleave="OnMouseUp"
         @onmousedown="OnSvgMouseDown"
         @onwheel="OnWheel"
         @onwheel:preventDefault="true">

        <g transform="translate(@panX, @panY) scale(@zoom)">

        <!-- Render edges -->
        @foreach (var edge in graph.Edges)
        {
            var source = graph.Nodes.FirstOrDefault(n => n.Id == edge.SourceNodeId);
            var target = graph.Nodes.FirstOrDefault(n => n.Id == edge.TargetNodeId);
            if (source != null && target != null)
            {
                var isSelected = selectedEdge == edge;
                var dashArray = edge.LineStyle switch
                {
                    EdgeLineStyle.Dashed => "8,8",
                    EdgeLineStyle.Dotted => "3,6",
                    _ => "none"
                };

                // Create a slightly curved path for a sketchy look
                var dx = target.X - source.X;
                var dy = target.Y - source.Y;
                var cx = source.X + dx / 2 + (dy * 0.1); // slight offset perpendicular to line
                var cy = source.Y + dy / 2 - (dx * 0.1);
                double targetXAdjusted = target.X;
                double targetYAdjusted = target.Y;
                if (dx != 0 || dy != 0)
                {
                    double halfWidth = target.Width / 2;
                    double halfHeight = target.Height / 2;
                    double absDx = Math.Abs(dx);
                    double absDy = Math.Abs(dy);
                    if (absDx * halfHeight > absDy * halfWidth)
                    {
                        targetXAdjusted = target.X - Math.Sign(dx) * halfWidth;
                        targetYAdjusted = target.Y - Math.Sign(dx) * halfWidth * dy / dx;
                    }
                    else
                    {
                        targetYAdjusted = target.Y - Math.Sign(dy) * halfHeight;
                        targetXAdjusted = target.X - Math.Sign(dy) * halfHeight * dx / dy;
                    }
                }
                var pathD = $"M {source.X} {source.Y} Q {cx} {cy} {targetXAdjusted} {targetYAdjusted}";

                // Text positioning logic
                // Simple quadratic bezier curve midpoint formula:
                // B(t) = (1-t)^2 P0 + 2(1-t)t P1 + t^2 P2
                // At t=0.5: B(0.5) = 0.25 P0 + 0.5 P1 + 0.25 P2
                double midX = 0.25 * source.X + 0.5 * cx + 0.25 * targetXAdjusted;
                double midY = 0.25 * source.Y + 0.5 * cy + 0.25 * targetYAdjusted;

                <g style="cursor: pointer;" @onclick="@(e => OnEdgeClick(e, edge))" @ondblclick="@(() => EditEdge(edge))" @onclick:stopPropagation="true">
                    <!-- Invisible thick path for easier clicking -->
                    <path d="@pathD" stroke="transparent" stroke-width="20" fill="none" />
                    <!-- Visible path -->
                    <path d="@pathD"
                          stroke="@(isSelected ? "var(--mud-palette-primary)" : "var(--mud-palette-text-primary)")"
                          stroke-width="@(isSelected ? "4" : "3")"
                          stroke-dasharray="@dashArray"
                          fill="none"
                          marker-end="url(#arrowhead@(isSelected ? "-selected" : ""))" />

                    @if (!string.IsNullOrEmpty(edge.Label) && editingEdgeId != edge.Id)
                    {
                        <rect x="@(midX - edge.Label.Length * 4 - 8)" y="@(midY - 12)" width="@(edge.Label.Length * 8 + 16)" height="24" fill="var(--mud-palette-surface)" stroke="var(--mud-palette-text-primary)" stroke-width="1" rx="4" ry="4" style="pointer-events: none;" />
                        <svg:text x="@midX" y="@(midY + 5)" text-anchor="middle" class="sketch-font" font-size="14" fill="var(--mud-palette-text-primary)" style="pointer-events: none;">@edge.Label</svg:text>
                    }
                    @if (editingEdgeId == edge.Id)
                    {
                        <foreignObject x="@(midX - 55)" y="@(midY - 20)" width="110" height="40" @onmousedown:stopPropagation="true" @ondblclick:stopPropagation="true">
                            <div xmlns="http://www.w3.org/1999/xhtml" style="width: 100%; height: 100%;">
                                <input id="edge-editor-@edge.Id"
                                       type="text"
                                       class="inline-editor-input"
                                       @bind="editingEdgeText"
                                       @bind:event="oninput"
                                       @onblur="CommitEdgeEdit"
                                       @onkeydown="OnEditorKeyDown" />
                            </div>
                        </foreignObject>
                    }
                </g>
            }
        }

        <!-- Render active connection line if drawing -->
        @if (isConnecting && activeSourceNode != null)
        {
            var dx = mouseX - activeSourceNode.X;
            var dy = mouseY - activeSourceNode.Y;
            var cx = activeSourceNode.X + dx / 2 + (dy * 0.1);
            var cy = activeSourceNode.Y + dy / 2 - (dx * 0.1);
            var pathD = $"M {activeSourceNode.X} {activeSourceNode.Y} Q {cx} {cy} {mouseX} {mouseY}";

            <path d="@pathD"
                  stroke="var(--mud-palette-primary)" stroke-width="3" stroke-dasharray="8,8" fill="none" />
        }

        <!-- Render nodes -->
        @foreach (var node in graph.Nodes)
        {
            var isSelectedNode = selectedNode == node;
            <g transform="translate(@node.X, @node.Y)"
               @onmousedown="@(e => OnNodeMouseDown(e, node))"
               @onmouseup="@(e => OnNodeMouseUp(e, node))"
               @ondblclick="@(() => EditNode(node))"
               class="graph-node" style="cursor: grab;">

                @if (node.Type == NodeType.Rectangle || node.Type == NodeType.RoundedRectangle || node.Type == NodeType.Stadium)
                {
                    double rx = node.Type == NodeType.Rectangle ? 0 : node.Type == NodeType.RoundedRectangle ? 10 : node.Height / 2;
                    <rect x="@(-node.Width/2)" y="@(-node.Height/2)" width="@node.Width" height="@node.Height" rx="@rx" ry="@rx"
                          fill="@(node == activeSourceNode ? "var(--mud-palette-primary-lighten)" : "var(--mud-palette-surface)")"
                          stroke="@(isSelectedNode ? "var(--mud-palette-primary)" : "var(--mud-palette-text-primary)")" stroke-width="@(isSelectedNode ? "4" : "2")" filter="url(#wobbly)" />
                }
                else if (node.Type == NodeType.Cylinder)
                {
                    <path d="M @(-node.Width/2) @(-node.Height/2 + 10) C @(-node.Width/2) @(-node.Height/2 - 10), @(node.Width/2) @(-node.Height/2 - 10), @(node.Width/2) @(-node.Height/2 + 10) L @(node.Width/2) @(node.Height/2 - 10) C @(node.Width/2) @(node.Height/2 + 10), @(-node.Width/2) @(node.Height/2 + 10), @(-node.Width/2) @(node.Height/2 - 10) Z M @(-node.Width/2) @(-node.Height/2 + 10) C @(-node.Width/2) @(-node.Height/2 + 30), @(node.Width/2) @(-node.Height/2 + 30), @(node.Width/2) @(-node.Height/2 + 10)"
                          fill="@(node == activeSourceNode ? "var(--mud-palette-primary-lighten)" : "var(--mud-palette-surface)")"
                          stroke="@(isSelectedNode ? "var(--mud-palette-primary)" : "var(--mud-palette-text-primary)")" stroke-width="@(isSelectedNode ? "4" : "2")" filter="url(#wobbly)" />
                }
                else if (node.Type == NodeType.Circle)
                {
                    <ellipse cx="0" cy="0" rx="@(node.Width/2)" ry="@(node.Height/2)"
                             fill="@(node == activeSourceNode ? "var(--mud-palette-primary-lighten)" : "var(--mud-palette-surface)")"
                             stroke="@(isSelectedNode ? "var(--mud-palette-primary)" : "var(--mud-palette-text-primary)")" stroke-width="@(isSelectedNode ? "4" : "2")" filter="url(#wobbly)" />
                }
                else if (node.Type == NodeType.Rhombus || node.Type == NodeType.Hexagon)
                {
                    string points = node.Type == NodeType.Rhombus ? $"0,{-node.Height/2} {node.Width/2},0 0,{node.Height/2} {-node.Width/2},0" : $"{node.Width/4},{-node.Height/2} {node.Width/2},0 {node.Width/4},{node.Height/2} {-node.Width/4},{node.Height/2} {-node.Width/2},0 {-node.Width/4},{-node.Height/2}";
                    <polygon points="@points"
                             fill="@(node == activeSourceNode ? "var(--mud-palette-primary-lighten)" : "var(--mud-palette-surface)")"
                             stroke="@(isSelectedNode ? "var(--mud-palette-primary)" : "var(--mud-palette-text-primary)")" stroke-width="@(isSelectedNode ? "4" : "2")" filter="url(#wobbly)" />
                }

                @if (editingNodeId != node.Id)
                {
                    <svg:text text-anchor="middle" dy=".3em" class="sketch-font" font-size="20" fill="var(--mud-palette-text-primary)" style="pointer-events: none;">@node.Label</svg:text>
                }
                else
                {
                    <foreignObject x="-55" y="-20" width="110" height="40" @onmousedown:stopPropagation="true" @ondblclick:stopPropagation="true">
                        <div xmlns="http://www.w3.org/1999/xhtml" style="width: 100%; height: 100%;">
                            <input id="node-editor-@node.Id"
                                   type="text"
                                   class="inline-editor-input"
                                   @bind="editingNodeText"
                                   @bind:event="oninput"
                                   @onblur="CommitNodeEdit"
                                   @onkeydown="OnEditorKeyDown" />
                        </div>
                    </foreignObject>
                }

                <!-- Resize Handle -->
                <polygon points="@(node.Width/2 - 10),@(node.Height/2) @(node.Width/2),@(node.Height/2 - 10) @(node.Width/2),@(node.Height/2)"
                         fill="var(--mud-palette-text-primary)" style="cursor: nwse-resize;"
                         @onmousedown="@(e => OnResizeMouseDown(e, node))" @onmousedown:stopPropagation="true" />
            </g>
        }

        <defs>
            <!-- Hand-drawn style arrowhead (stroke instead of filled polygon) -->
            <marker id="arrowhead" markerWidth="10" markerHeight="10" refX="9" refY="5" orient="auto">
                <path d="M 0 0 L 10 5 L 0 10 M 10 5 L 4 5" stroke="var(--mud-palette-text-primary)" stroke-width="2" fill="none" stroke-linejoin="round" stroke-linecap="round" />
            </marker>
            <marker id="arrowhead-selected" markerWidth="10" markerHeight="10" refX="9" refY="5" orient="auto">
                <path d="M 0 0 L 10 5 L 0 10 M 10 5 L 4 5" stroke="var(--mud-palette-primary)" stroke-width="2" fill="none" stroke-linejoin="round" stroke-linecap="round" />
            </marker>
            <filter id="wobbly" x="-10%" y="-10%" width="120%" height="120%">
                <feTurbulence type="fractalNoise" baseFrequency="0.04" numOctaves="2" result="noise" />
                <feDisplacementMap in="SourceGraphic" in2="noise" scale="3" xChannelSelector="R" yChannelSelector="G" />
            </filter>
        </defs>
        </g>
    </svg>

    <!-- Export Drawer -->
    <MudDrawer @bind-Open="_exportDrawerOpen" Overlay="false" Anchor="Anchor.End" Elevation="1" Variant="@DrawerVariant.Temporary" Width="450px" Class="p-8" Style="z-index: 1001;">
        <MudDrawerHeader Class="px-0 pt-0">
            <MudText Typo="Typo.h5">Export Diagram</MudText>
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="ToggleExportDrawer" />
        </MudDrawerHeader>

        <MudText Typo="Typo.subtitle2" Class="mb-2">Mermaid Preview</MudText>
        <MudPaper Elevation="0" Class="p-4 mb-6 border-solid mud-border-lines-default rounded" Style="min-height: 200px; background-color: var(--mud-palette-surface); overflow: auto;">
            <div id="mermaid-preview" class="mermaid-render-area w-100 h-100"></div>
        </MudPaper>

        <MudText Typo="Typo.subtitle2" Class="mb-2">Mermaid Source</MudText>
        <MudPaper Elevation="0" Class="p-4 mb-6 border-solid mud-border-lines-default rounded" Style="background-color: var(--mud-palette-background-grey); position: relative; font-family: monospace;">
            <pre style="margin: 0; white-space: pre-wrap; word-wrap: break-word; color: var(--mud-palette-text-primary);" id="mermaid-source-code"><code>@mermaidCode</code></pre>
        </MudPaper>

        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ContentCopy" OnClick="CopyMermaidCodeToClipboard" FullWidth="true" Class="mb-2">Copy Code</MudButton>
        <div class="d-flex justify-space-between mt-2">
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Download" OnClick="DownloadJson">JSON</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Download" OnClick="DownloadMarkdown">MD</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Image" OnClick="DownloadPng">PNG</MudButton>
        </div>
    </MudDrawer>
</div>

<style>
    .graph-node:active {
        cursor: grabbing !important;
    }
</style>

@code {
    private Graph graph = new Graph();
    private string mermaidCode = "graph TD;";

    // State variables for interactions

    // Zoom & Pan State
    private double zoom = 1.0;
    private double panX = 0;
    private double panY = 0;
    private bool isPanning = false;
    private double panStartMouseX;
    private double panStartMouseY;
    private double panStartX;
    private double panStartY;

    private async Task DownloadJson()
    {
        var json = System.Text.Json.JsonSerializer.Serialize(graph, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        await MermaidInterop.DownloadTextAsync("diagram.json", json);
    }

    private async Task DownloadMarkdown()
    {
        await MermaidInterop.DownloadTextAsync("diagram.md", mermaidCode);
    }

    private async Task DownloadPng()
    {
        await MermaidInterop.DownloadSvgAsPngAsync("mermaid-preview", "diagram.png");
    }

    private void OnSvgMouseDown(MouseEventArgs e)
    {
        if (e.Button == 0 && !e.ShiftKey && draggingNode == null && !isConnecting)
        {
             isPanning = true;
             panStartMouseX = e.ClientX;
             panStartMouseY = e.ClientY;
             panStartX = panX;
             panStartY = panY;
        }
        else if (e.Button == 1) // Middle mouse
        {
             isPanning = true;
             panStartMouseX = e.ClientX;
             panStartMouseY = e.ClientY;
             panStartX = panX;
             panStartY = panY;
        }
    }

    private void OnWheel(WheelEventArgs e)
    {
        double zoomFactor = 1.1;
        double oldZoom = zoom;

        if (e.DeltaY < 0) zoom *= zoomFactor;
        else if (e.DeltaY > 0) zoom /= zoomFactor;

        if (zoom < 0.1) zoom = 0.1;
        if (zoom > 5.0) zoom = 5.0;

        double mouseX = e.ClientX;
        double mouseY = e.ClientY;

        panX = mouseX - (mouseX - panX) * (zoom / oldZoom);
        panY = mouseY - (mouseY - panY) * (zoom / oldZoom);
    }

    private void ZoomIn()
    {
        double oldZoom = zoom;
        zoom *= 1.2;
        if (zoom > 5.0) zoom = 5.0;
        panX = panX * (zoom / oldZoom);
        panY = panY * (zoom / oldZoom);
    }

    private void ZoomOut()
    {
        double oldZoom = zoom;
        zoom /= 1.2;
        if (zoom < 0.1) zoom = 0.1;
        panX = panX * (zoom / oldZoom);
        panY = panY * (zoom / oldZoom);
    }

    private void ResetZoomPan()
    {
        zoom = 1.0;
        panX = 0;
        panY = 0;
    }

    private MermaidEditor.Models.Edge? selectedEdge;
    private double edgeClickX;
    private double edgeClickY;
    private Node? selectedNode;
    private double nodeClickX;
    private double nodeClickY;
    private ElementReference containerRef;
    private int nodeCounter = 1;
    private Node? draggingNode;
    private double dragOffsetX;
    private double dragOffsetY;
    private Node? activeSourceNode;
    private bool isConnecting;
    private double mouseX;
    private double mouseY;
    private Node? resizingNode;
    private double resizeStartWidth;
    private double resizeStartHeight;
    private double resizeStartMouseX;
    private double resizeStartMouseY;

    // Export Drawer State
    private bool _exportDrawerOpen = false;

    // Inline Editing State
    private string? editingNodeId;
    private string editingNodeText = string.Empty;
    private string? editingEdgeId;
    private string editingEdgeText = string.Empty;

    private void ToggleExportDrawer()
    {
        _exportDrawerOpen = !_exportDrawerOpen;
    }

    private async Task CopyMermaidCodeToClipboard()
    {
        await MermaidInterop.CopyToClipboardAsync(mermaidCode);
    }

    private async Task EditNode(Node node)
    {
        editingNodeId = node.Id;
        editingNodeText = node.Label;

        // Wait for render so the input element exists
        await Task.Delay(50);
        await MermaidInterop.FocusElementAsync($"node-editor-{node.Id}");
    }

    private async Task CommitNodeEdit()
    {
        if (editingNodeId != null)
        {
            var node = graph.Nodes.FirstOrDefault(n => n.Id == editingNodeId);
            if (node != null)
            {
                node.Label = editingNodeText;

                // Adjust node width based on label length to ensure text fits
                // Rough estimate: each character takes ~10px width
                double estimatedTextWidth = Math.Max(node.Label.Length * 10 + 40, node.Type == NodeType.Circle ? 80 : 120);
                if (node.Width < estimatedTextWidth)
                {
                    node.Width = estimatedTextWidth;
                    if (node.Type == NodeType.Circle)
                    {
                        node.Height = estimatedTextWidth;
                    }
                }

                // Apply a simple repulsion algorithm to separate overlapping nodes
                ResolveOverlaps();

                await UpdateMermaidPreviewAsync();
            }
            editingNodeId = null;
        }
    }

    private void ResolveOverlaps()
    {
        bool moved;
        int iterations = 0;
        int maxIterations = 50;
        do
        {
            moved = false;
            for (int i = 0; i < graph.Nodes.Count; i++)
            {
                for (int j = i + 1; j < graph.Nodes.Count; j++)
                {
                    var n1 = graph.Nodes[i];
                    var n2 = graph.Nodes[j];

                    double dx = n2.X - n1.X;
                    double dy = n2.Y - n1.Y;
                    double dist = Math.Sqrt(dx * dx + dy * dy);

                    // Estimate bounding radius (approximate based on diagonal)
                    double r1 = Math.Sqrt((n1.Width/2)*(n1.Width/2) + (n1.Height/2)*(n1.Height/2));
                    double r2 = Math.Sqrt((n2.Width/2)*(n2.Width/2) + (n2.Height/2)*(n2.Height/2));
                    double minD = r1 + r2 + 20; // 20px padding

                    if (dist < minD)
                    {
                        moved = true;
                        // Avoid division by zero
                        if (dist == 0)
                        {
                            dx = 1;
                            dy = 0;
                            dist = 1;
                        }

                        double pushDist = (minD - dist) / 2;
                        double pushX = (dx / dist) * pushDist;
                        double pushY = (dy / dist) * pushDist;

                        n1.X -= pushX;
                        n1.Y -= pushY;
                        n2.X += pushX;
                        n2.Y += pushY;
                    }
                }
            }
            iterations++;
        } while (moved && iterations < maxIterations);
    }

    private async Task OnEditorKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == "Escape")
        {
            await CommitNodeEdit();
            await CommitEdgeEdit();
        }
    }

    private async Task EditEdge(MermaidEditor.Models.Edge edge)
    {
        editingEdgeId = edge.Id;
        editingEdgeText = edge.Label;

        await Task.Delay(50);
        await MermaidInterop.FocusElementAsync($"edge-editor-{edge.Id}");
    }

    private async Task CommitEdgeEdit()
    {
        if (editingEdgeId != null)
        {
            var edge = graph.Edges.FirstOrDefault(e => e.Id == editingEdgeId);
            if (edge != null)
            {
                edge.Label = editingEdgeText;
                await UpdateMermaidPreviewAsync();
            }
            editingEdgeId = null;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var savedGraph = await LocalStorage.GetItemAsync<Graph>("mermaid_graph");
        if (savedGraph != null && savedGraph.Nodes.Any())
        {
            graph = savedGraph;
            foreach (var node in graph.Nodes)
            {
                if (node.Id.StartsWith("Node") && int.TryParse(node.Id.Substring(4), out int idNum))
                {
                    if (idNum >= nodeCounter) nodeCounter = idNum + 1;
                }
            }
            await UpdateMermaidPreviewAsync();
        }
        else
        {
            await AddNode(NodeType.Rectangle);
        }
    }

    private NodeType? draggedShapeType;

    private void OnDragStartShape(NodeType type)
    {
        draggedShapeType = type;
    }

    private async Task OnCanvasDrop(DragEventArgs e)
    {
        if (draggedShapeType.HasValue)
        {
            var id = $"Node{nodeCounter}";
            double localX = (e.ClientX - panX) / zoom;
            double localY = (e.ClientY - panY) / zoom;

            graph.Nodes.Add(new Node
            {
                Id = id,
                Label = $"Node {nodeCounter}",
                X = localX,
                Y = localY,
                Type = draggedShapeType.Value,
                Width = draggedShapeType.Value == NodeType.Circle ? 80 : 120,
                Height = draggedShapeType.Value == NodeType.Circle ? 80 : 60
            });
            nodeCounter++;
            draggedShapeType = null;
            await UpdateMermaidPreviewAsync();
        }
    }

    private async Task AddNode(NodeType type)
    {
        var id = $"Node{nodeCounter}";
        // Add to roughly center of view
        double centerX = (400 - panX) / zoom;
        double centerY = (300 - panY) / zoom;
        // Default slightly offset if multiple created
        double offsetX = (nodeCounter * 20 % 100);
        double offsetY = (nodeCounter * 20 % 100);

        graph.Nodes.Add(new Node
        {
            Id = id,
            Label = $"Node {nodeCounter}",
            X = centerX + offsetX,
            Y = centerY + offsetY,
            Type = type,
            Width = type == NodeType.Circle ? 80 : 120,
            Height = type == NodeType.Circle ? 80 : 60
        });
        nodeCounter++;
        await UpdateMermaidPreviewAsync();
    }

    private async Task ClearGraph()
    {
        graph = new Graph();
        nodeCounter = 1;
        await UpdateMermaidPreviewAsync();
    }

    private void OnNodeMouseDown(MouseEventArgs e, Node node)
    {
        if (e.Button == 1) return;
        selectedNode = node;
        nodeClickX = e.ClientX;
        nodeClickY = e.ClientY - (node.Height / 2 * zoom);
        if (e.ShiftKey)
        {
            // Start connecting
            isConnecting = true;
            activeSourceNode = node;
            mouseX = node.X;
            mouseY = node.Y;
        }
        else
        {
            // Start dragging
            draggingNode = node;
            double localX = (e.ClientX - panX) / zoom;
            double localY = (e.ClientY - panY) / zoom;
            dragOffsetX = localX - node.X;
            dragOffsetY = localY - node.Y;
        }
    }

    private async Task OnNodeMouseUp(MouseEventArgs e, Node targetNode)
    {
        if (isConnecting && activeSourceNode != null && activeSourceNode != targetNode)
        {
            // Check if edge already exists
            bool edgeExists = graph.Edges.Any(ed => ed.SourceNodeId == activeSourceNode.Id && ed.TargetNodeId == targetNode.Id);
            if (!edgeExists)
            {
                graph.Edges.Add(new MermaidEditor.Models.Edge
                {
                    Id = Guid.NewGuid().ToString(),
                    SourceNodeId = activeSourceNode.Id,
                    TargetNodeId = targetNode.Id,
                    Label = ""
                });
                await UpdateMermaidPreviewAsync();
            }
        }

        // Reset state
        isConnecting = false;
        activeSourceNode = null;
        draggingNode = null;
    }

    private void OnResizeMouseDown(MouseEventArgs e, Node node)
    {
        resizingNode = node;
        resizeStartWidth = node.Width;
        resizeStartHeight = node.Height;
        resizeStartMouseX = e.ClientX;
        resizeStartMouseY = e.ClientY;
    }

    private void OnMouseMove(MouseEventArgs e)
    {
        if (isPanning)
        {
            panX = panStartX + (e.ClientX - panStartMouseX);
            panY = panStartY + (e.ClientY - panStartMouseY);
        }
        else if (resizingNode != null)
        {
            double deltaX = (e.ClientX - resizeStartMouseX) / zoom;
            double deltaY = (e.ClientY - resizeStartMouseY) / zoom;

            // we're dragging from the bottom right corner (width/2, height/2),
            // so modifying the width by deltaX*2 ensures the center remains fixed
            double newWidth = resizeStartWidth + deltaX * 2;
            double newHeight = resizeStartHeight + deltaY * 2;

            if (resizingNode.Type == NodeType.Circle)
            {
                // Maintain aspect ratio for circles
                double size = Math.Max(40, Math.Max(newWidth, newHeight));
                resizingNode.Width = size;
                resizingNode.Height = size;
            }
            else
            {
                if (newWidth >= 40) resizingNode.Width = newWidth;
                if (newHeight >= 40) resizingNode.Height = newHeight;
            }
        }
        else if (draggingNode != null)
        {
            double localX = (e.ClientX - panX) / zoom;
            double localY = (e.ClientY - panY) / zoom;
            draggingNode.X = localX - dragOffsetX;
            draggingNode.Y = localY - dragOffsetY;
        }
        else if (isConnecting)
        {
            mouseX = (e.ClientX - panX) / zoom;
            mouseY = (e.ClientY - panY) / zoom;
        }
    }

    private void OnEdgeClick(MouseEventArgs e, MermaidEditor.Models.Edge edge)
    {
        selectedEdge = edge;
        selectedNode = null;
        edgeClickX = e.ClientX;
        edgeClickY = e.ClientY;
    }

    private async Task DeleteNode(Node node)
    {
        graph.Nodes.Remove(node);
        graph.Edges.RemoveAll(e => e.SourceNodeId == node.Id || e.TargetNodeId == node.Id);
        selectedNode = null;
        await UpdateMermaidPreviewAsync();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Delete" || e.Key == "Backspace")
        {
            bool updated = false;
            if (selectedNode != null && editingNodeId == null)
            {
                graph.Nodes.Remove(selectedNode);
                graph.Edges.RemoveAll(ed => ed.SourceNodeId == selectedNode.Id || ed.TargetNodeId == selectedNode.Id);
                selectedNode = null;
                updated = true;
            }
            if (selectedEdge != null)
            {
                graph.Edges.Remove(selectedEdge);
                selectedEdge = null;
                updated = true;
            }
            if (updated)
            {
                await UpdateMermaidPreviewAsync();
            }
        }
    }

    private async Task SetEdgeStyle(MermaidEditor.Models.Edge edge, EdgeLineStyle style)
    {
        edge.LineStyle = style;
        await UpdateMermaidPreviewAsync();
    }

    private async Task DeleteEdge(MermaidEditor.Models.Edge edge)
    {
        graph.Edges.Remove(edge);
        selectedEdge = null;
        await UpdateMermaidPreviewAsync();
    }

    private async Task OnMouseUp(MouseEventArgs e)
    {
        if (isPanning) isPanning = false;

        if (resizingNode != null)
        {
            resizingNode = null;
            await UpdateMermaidPreviewAsync();
            if (selectedNode != null)
            {
                nodeClickX = e.ClientX;
                nodeClickY = e.ClientY - (selectedNode.Height / 2 * zoom);
            }
        }

        if (draggingNode != null)
        {
            draggingNode = null;
            await UpdateMermaidPreviewAsync();
            if (selectedNode != null)
            {
                nodeClickX = e.ClientX;
                nodeClickY = e.ClientY - (selectedNode.Height / 2 * zoom);
            }
        }

        if (isConnecting)
        {
            isConnecting = false;
            activeSourceNode = null;
        }

        // Deselect edge and node if clicking on empty space (not dragging or connecting or resizing)
        if (!isConnecting && draggingNode == null && resizingNode == null)
        {
            selectedEdge = null;
            selectedNode = null;
        }
    }

    private async Task UpdateMermaidPreviewAsync()
    {
        mermaidCode = MermaidSerializer.Serialize(graph);
        await MermaidInterop.RenderMermaidAsync("mermaid-preview", mermaidCode);
        await LocalStorage.SetItemAsync("mermaid_graph", graph);
    }
}
