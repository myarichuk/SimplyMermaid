@page "/"
@using MermaidEditor.Models
@using MermaidEditor.Services
@using Blazored.LocalStorage
@inject MermaidJsInterop MermaidInterop
@inject ILocalStorageService LocalStorage
@inject IJSRuntime JS

<PageTitle>Mermaid Editor</PageTitle>

    <div class="editor-container canvas-background sketch-font w-100 h-100 position-relative" @onkeydown="OnKeyDown" tabindex="0" @ref="containerRef"
         @ondragover:preventDefault="true" @ondrop="OnCanvasDrop">

    <!-- Sleek Floating Toolbar -->
    <div class="floating-toolbar px-4 py-2" style="width: auto; white-space: nowrap;">
        <div class="d-flex align-center gap-2">
            <MudText Typo="Typo.h6" Class="sketch-font mr-2" Style="color: var(--mud-palette-primary); font-weight: bold; pointer-events: none; user-select: none;">SimplyMermaid</MudText>

            <div style="width: 1px; height: 24px; background-color: var(--mud-palette-divider); margin: 0 4px;"></div>

            <MudSelect T="DiagramType" Value="graph.DiagramType" ValueChanged="OnDiagramTypeChanged" Dense="true" Underline="false" Style="width: 120px;" Class="mt-0">
                <MudSelectItem Value="DiagramType.Flowchart">Flowchart</MudSelectItem>
                <MudSelectItem Value="DiagramType.Sequence">Sequence</MudSelectItem>
            </MudSelect>

            <div style="width: 1px; height: 24px; background-color: var(--mud-palette-divider); margin: 0 4px;"></div>

            <MudTooltip Text="Select / Lasso (Default)">
                <MudIconButton Icon="@Icons.Material.Filled.Mouse" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" />
            </MudTooltip>

            <div style="width: 1px; height: 24px; background-color: var(--mud-palette-divider); margin: 0 4px;"></div>

            <MudTooltip Text="Undo (Ctrl+Z)">
                <MudIconButton Icon="@Icons.Material.Filled.Undo" Color="Color.Default" OnClick="Undo" Disabled="@(commandManager.UndoStack.Count == 0)" Size="Size.Small" />
            </MudTooltip>

            <MudTooltip Text="Redo (Ctrl+Y)">
                <MudIconButton Icon="@Icons.Material.Filled.Redo" Color="Color.Default" OnClick="Redo" Disabled="@(commandManager.RedoStack.Count == 0)" Size="Size.Small" />
            </MudTooltip>

            <div style="width: 1px; height: 24px; background-color: var(--mud-palette-divider); margin: 0 4px;"></div>

            <MudTooltip Text="Clear Canvas">
                <MudIconButton Icon="@Icons.Material.Filled.Clear" Color="Color.Error" OnClick="ClearGraph" Size="Size.Small" />
            </MudTooltip>

            <div style="width: 1px; height: 24px; background-color: var(--mud-palette-divider); margin: 0 4px;"></div>

            <MudTooltip Text="Zoom Out">
                <MudIconButton Icon="@Icons.Material.Filled.Remove" Color="Color.Default" OnClick="ZoomOut" Size="Size.Small" />
            </MudTooltip>

            <div style="width: 80px; display: flex; align-items: center;" class="mx-1">
                <MudSlider @bind-Value="zoom" Min="0.1" Max="5.0" Step="0.1" Size="Size.Small" Color="Color.Primary" />
            </div>

            <MudText Typo="Typo.body2" Class="mx-1" Style="min-width: 40px;">@(Math.Round(zoom * 100))%</MudText>

            <MudTooltip Text="Zoom In">
                <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Default" OnClick="ZoomIn" Size="Size.Small" />
            </MudTooltip>

            <MudTooltip Text="Reset View">
                <MudIconButton Icon="@Icons.Material.Filled.FilterCenterFocus" Color="Color.Default" OnClick="ResetZoomPan" Size="Size.Small" />
            </MudTooltip>

            <div style="width: 1px; height: 24px; background-color: var(--mud-palette-divider); margin: 0 4px;"></div>

            <MudTooltip Text="Import">
                <MudIconButton Icon="@Icons.Material.Filled.Upload" Color="Color.Info" OnClick="ToggleImportDrawer" Size="Size.Small" />
            </MudTooltip>

            <MudTooltip Text="Export">
                <MudIconButton Icon="@Icons.Material.Filled.Download" Color="Color.Info" OnClick="ToggleExportDrawer" Size="Size.Small" />
            </MudTooltip>

            <div style="width: 1px; height: 24px; background-color: var(--mud-palette-divider); margin: 0 4px;"></div>

            <MudMenu Icon="@Icons.Material.Filled.AddBox" Color="Color.Success" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter" Dense="true" Size="Size.Medium">
                <ActivatorContent>
                    <MudTooltip Text="Add Node">
                        <MudIconButton Icon="@Icons.Material.Filled.AddBox" Color="Color.Success" Size="Size.Small" />
                    </MudTooltip>
                </ActivatorContent>
                <ChildContent>
                    <MudMenuItem OnClick="@(() => AddNode(NodeType.Rectangle))">
                        <div class="d-flex align-center"><svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" class="mr-2"><rect x="3" y="6" width="18" height="12"></rect></svg> Rectangle</div>
                    </MudMenuItem>
                    <MudMenuItem OnClick="@(() => AddNode(NodeType.RoundedRectangle))">
                        <div class="d-flex align-center"><svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" class="mr-2"><rect x="3" y="6" width="18" height="12" rx="4"></rect></svg> Rounded Rectangle</div>
                    </MudMenuItem>
                    <MudMenuItem OnClick="@(() => AddNode(NodeType.Stadium))">
                        <div class="d-flex align-center"><svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" class="mr-2"><rect x="3" y="6" width="18" height="12" rx="6"></rect></svg> Stadium</div>
                    </MudMenuItem>
                    <MudMenuItem OnClick="@(() => AddNode(NodeType.Cylinder))">
                        <div class="d-flex align-center"><svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" class="mr-2"><path d="M4 8c0-2.2 3.6-4 8-4s8 1.8 8 4v8c0 2.2-3.6 4-8 4s-8-1.8-8-4V8z"></path><path d="M4 8c0 2.2 3.6 4 8 4s8-1.8 8-4"></path></svg> Database</div>
                    </MudMenuItem>
                    <MudMenuItem OnClick="@(() => AddNode(NodeType.Circle))">
                        <div class="d-flex align-center"><svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" class="mr-2"><circle cx="12" cy="12" r="8"></circle></svg> Circle</div>
                    </MudMenuItem>
                    <MudMenuItem OnClick="@(() => AddNode(NodeType.Rhombus))">
                        <div class="d-flex align-center"><svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" class="mr-2"><polygon points="12 3 21 12 12 21 3 12 12 3"></polygon></svg> Rhombus</div>
                    </MudMenuItem>
                    <MudMenuItem OnClick="@(() => AddNode(NodeType.Hexagon))">
                        <div class="d-flex align-center"><svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" class="mr-2"><polygon points="12 2 21 7 21 17 12 22 3 17 3 7 12 2"></polygon></svg> Hexagon</div>
                    </MudMenuItem>
                </ChildContent>
            </MudMenu>
        </div>
    </div>

    @if (selectedEdge != null && editingEdgeId == null)
    {
        <div class="floating-toolbar" style="top: @(contextMenuY)px; left: @(contextMenuX)px; transform: translate(0, 0); margin-top: 5px; margin-left: 5px; z-index: 1000;" @onmousedown:stopPropagation="true" @onmousemove:stopPropagation="true" @ontouchstart:stopPropagation="true" @ontouchmove:stopPropagation="true">
            <MudIconButton Icon="@Icons.Material.Filled.HorizontalRule" Color="@(selectedEdge.LineStyle == EdgeLineStyle.Solid ? Color.Primary : Color.Default)" OnClick="@(() => SetEdgeStyle(selectedEdge, EdgeLineStyle.Solid))" title="Solid Line" />
            <MudIconButton Icon="@Icons.Material.Filled.MoreHoriz" Color="@(selectedEdge.LineStyle == EdgeLineStyle.Dashed ? Color.Primary : Color.Default)" OnClick="@(() => SetEdgeStyle(selectedEdge, EdgeLineStyle.Dashed))" title="Dashed Line" />
            <MudIconButton Icon="@Icons.Material.Filled.LensBlur" Color="@(selectedEdge.LineStyle == EdgeLineStyle.Dotted ? Color.Primary : Color.Default)" OnClick="@(() => SetEdgeStyle(selectedEdge, EdgeLineStyle.Dotted))" title="Dotted Line" />
            <div style="width: 1px; height: 24px; background-color: var(--mud-palette-divider); margin: 0 8px;"></div>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="@(() => EditEdge(selectedEdge))" title="Edit Label" />
            <div style="width: 1px; height: 24px; background-color: var(--mud-palette-divider); margin: 0 8px;"></div>
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => DeleteEdge(selectedEdge))" title="Delete Edge" />
        </div>
    }

    @if (selectedNode != null && editingNodeId == null)
    {
        <div class="floating-toolbar" style="top: @(contextMenuY)px; left: @(contextMenuX)px; transform: translate(0, 0); margin-top: 5px; margin-left: 5px; z-index: 1000;" @onmousedown:stopPropagation="true" @onmousemove:stopPropagation="true" @ontouchstart:stopPropagation="true" @ontouchmove:stopPropagation="true">
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="@(() => EditNode(selectedNode))" title="Edit Label" />
            <div style="width: 1px; height: 24px; background-color: var(--mud-palette-divider); margin: 0 8px;"></div>
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => DeleteNode(selectedNode))" title="Delete Node" />
        </div>
    }

    <!-- Full Screen Canvas -->
    <svg id="pretty-chart" class="graph-canvas w-100 h-100"
         style="cursor: @(isPanning ? "grabbing" : "crosshair"); touch-action: none;"
         @onmousemove="OnMouseMove"
         @onmouseup="OnMouseUp"
         @onmouseleave="OnMouseUp"
         @onmousedown="OnSvgMouseDown"
         @onmousedown:preventDefault="true"
         @ontouchstart="OnSvgTouchStart"
         @ontouchmove="OnSvgTouchMove"
         @ontouchend="OnSvgTouchEnd"
         @ontouchcancel="OnSvgTouchEnd"
         @ontouchmove:preventDefault="true"
         @oncontextmenu="OnSvgContextMenu"
         @oncontextmenu:preventDefault="true"
         @onwheel="OnWheel"
         @onwheel:preventDefault="true">

        <g transform="translate(@panX, @panY) scale(@zoom)">

        @if (graph.DiagramType == DiagramType.Sequence)
        {
            @foreach (var node in graph.Nodes)
            {
                <line x1="@node.X" y1="@(node.Y + node.Height/2)" x2="@node.X" y2="@(node.Y + 2000)" stroke="var(--mud-palette-text-primary)" stroke-dasharray="4,4" stroke-width="2" style="pointer-events: none; opacity: 0.5;" />
            }
        }

        <!-- Render edges -->
        @{
            int edgeIndex = 1;
        }
        @foreach (var edge in graph.Edges)
        {
            var source = graph.Nodes.FirstOrDefault(n => n.Id == edge.SourceNodeId);
            var target = graph.Nodes.FirstOrDefault(n => n.Id == edge.TargetNodeId);
            if (source != null && target != null)
            {
                var isSelected = selectedEdge == edge || selectedEdges.Contains(edge);
                var dashArray = edge.LineStyle switch
                {
                    EdgeLineStyle.Dashed => "8,8",
                    EdgeLineStyle.Dotted => "3,6",
                    _ => "none"
                };

                // Create a slightly curved path for a sketchy look
                var dx = target.X - source.X;
                var dy = target.Y - source.Y;
                var cx = source.X + dx / 2 + (dy * 0.1); // slight offset perpendicular to line
                var cy = source.Y + dy / 2 - (dx * 0.1);
                double targetXAdjusted = target.X;
                double targetYAdjusted = target.Y;
                if (dx != 0 || dy != 0)
                {
                    double halfWidth = target.Width / 2;
                    double halfHeight = target.Height / 2;

                    if (target.Type == NodeType.Circle)
                    {
                        double t = 1.0 / Math.Sqrt((dx * dx) / (halfWidth * halfWidth) + (dy * dy) / (halfHeight * halfHeight));
                        targetXAdjusted = target.X - dx * t;
                        targetYAdjusted = target.Y - dy * t;
                    }
                    else if (target.Type == NodeType.Rhombus)
                    {
                        double t = 1.0 / (Math.Abs(dx) / halfWidth + Math.Abs(dy) / halfHeight);
                        targetXAdjusted = target.X - dx * t;
                        targetYAdjusted = target.Y - dy * t;
                    }
                    else if (target.Type == NodeType.Hexagon)
                    {
                        double vx = Math.Abs(dx);
                        double vy = Math.Abs(dy);
                        double t1 = 1.0 / (vx / halfWidth + vy / target.Height);
                        double t2 = vy > 0 ? halfHeight / vy : double.PositiveInfinity;
                        double t = Math.Min(t1, t2);
                        targetXAdjusted = target.X - dx * t;
                        targetYAdjusted = target.Y - dy * t;
                    }
                    else
                    {
                        double absDx = Math.Abs(dx);
                        double absDy = Math.Abs(dy);
                        if (absDx * halfHeight > absDy * halfWidth)
                        {
                            targetXAdjusted = target.X - Math.Sign(dx) * halfWidth;
                            targetYAdjusted = target.Y - Math.Sign(dx) * halfWidth * dy / dx;
                        }
                        else
                        {
                            targetYAdjusted = target.Y - Math.Sign(dy) * halfHeight;
                            targetXAdjusted = target.X - Math.Sign(dy) * halfHeight * dx / dy;
                        }
                    }

                    // Add buffer distance to prevent arrowhead from overlapping the node outline
                    double bufferDistance = 8.0; // Arrowhead size + some margin
                    double distToAdjusted = Math.Sqrt(Math.Pow(targetXAdjusted - cx, 2) + Math.Pow(targetYAdjusted - cy, 2));
                    if (distToAdjusted > bufferDistance)
                    {
                        targetXAdjusted = targetXAdjusted - (targetXAdjusted - cx) * (bufferDistance / distToAdjusted);
                        targetYAdjusted = targetYAdjusted - (targetYAdjusted - cy) * (bufferDistance / distToAdjusted);
                    }
                }
                var pathD = $"M {source.X} {source.Y} Q {cx} {cy} {targetXAdjusted} {targetYAdjusted}";

                // Text positioning logic
                // Simple quadratic bezier curve midpoint formula:
                // B(t) = (1-t)^2 P0 + 2(1-t)t P1 + t^2 P2
                // At t=0.5: B(0.5) = 0.25 P0 + 0.5 P1 + 0.25 P2
                double midX = 0.25 * source.X + 0.5 * cx + 0.25 * targetXAdjusted;
                double midY = 0.25 * source.Y + 0.5 * cy + 0.25 * targetYAdjusted;

                string displayLabel = string.IsNullOrEmpty(edge.Label) && graph.DiagramType == DiagramType.Sequence ? $"({edgeIndex})" : edge.Label;

                <g style="cursor: pointer;" @onclick="@(e => OnEdgeClick(e, edge))" @oncontextmenu="@(e => OnEdgeContextMenu(e, edge))" @oncontextmenu:preventDefault="true" @oncontextmenu:stopPropagation="true" @ondblclick="@(() => EditEdge(edge))" @onclick:stopPropagation="true" @ontouchstart="@(e => OnEdgeTouchStart(e, edge))" @ontouchstart:stopPropagation="true" @ontouchstart:preventDefault="true">
                    <!-- Invisible thick path for easier clicking -->
                    <path d="@pathD" stroke="transparent" stroke-width="20" fill="none" />
                    <!-- Visible path -->
                    <path d="@pathD"
                          stroke="@(isSelected ? "var(--mud-palette-primary)" : "var(--mud-palette-text-primary)")"
                          stroke-width="@(isSelected ? "4" : "3")"
                          stroke-dasharray="@dashArray"
                          fill="none"
                          marker-end="url(#arrowhead@(isSelected ? "-selected" : ""))" />

                    @if (!string.IsNullOrEmpty(displayLabel) && editingEdgeId != edge.Id)
                    {
                        <rect x="@(midX - displayLabel.Length * 4 - 8)" y="@(midY - 12)" width="@(displayLabel.Length * 8 + 16)" height="24" fill="var(--mud-palette-surface)" stroke="var(--mud-palette-text-primary)" stroke-width="1" rx="4" ry="4" style="pointer-events: none;" />
                        <svg:text x="@midX" y="@(midY + 5)" text-anchor="middle" class="sketch-font" font-size="14" fill="var(--mud-palette-text-primary)" style="pointer-events: none;">@displayLabel</svg:text>
                    }
                    @if (editingEdgeId == edge.Id)
                    {
                        <foreignObject x="@(midX - 55)" y="@(midY - 20)" width="110" height="40" @onmousedown:stopPropagation="true" @ondblclick:stopPropagation="true">
                            <div xmlns="http://www.w3.org/1999/xhtml" style="width: 100%; height: 100%;">
                                <input id="edge-editor-@edge.Id"
                                       type="text"
                                       class="inline-editor-input"
                                       @bind="editingEdgeText"
                                       @bind:event="oninput"
                                       @onblur="CommitEdgeEdit"
                                       @onkeydown="OnEditorKeyDown" />
                            </div>
                        </foreignObject>
                    }
                </g>
                edgeIndex++;
            }
        }

        <!-- Render active connection line if drawing -->
        @if (isConnecting && activeSourceNode != null)
        {
            var dx = mouseX - activeSourceNode.X;
            var dy = mouseY - activeSourceNode.Y;
            var cx = activeSourceNode.X + dx / 2 + (dy * 0.1);
            var cy = activeSourceNode.Y + dy / 2 - (dx * 0.1);
            var pathD = $"M {activeSourceNode.X} {activeSourceNode.Y} Q {cx} {cy} {mouseX} {mouseY}";

            <path d="@pathD"
                  stroke="var(--mud-palette-primary)" stroke-width="3" stroke-dasharray="8,8" fill="none" />
        }

        @if (isLassoing)
        {
            <rect x="@(Math.Min(lassoStartX, lassoCurrentX))" y="@(Math.Min(lassoStartY, lassoCurrentY))"
                  width="@(Math.Abs(lassoCurrentX - lassoStartX))" height="@(Math.Abs(lassoCurrentY - lassoStartY))"
                  fill="var(--mud-palette-primary)" fill-opacity="0.1"
                  stroke="var(--mud-palette-primary)" stroke-width="2" stroke-dasharray="4,4"
                  style="pointer-events: none;" />
        }

        <!-- Render nodes -->
        @foreach (var node in graph.Nodes)
        {
            var isSelectedNode = selectedNode == node || selectedNodes.Contains(node);

            double handleX = node.Width / 2;
            double handleY = node.Height / 2;

            if (node.Type == NodeType.Rhombus)
            {
                handleX = node.Width / 4;
                handleY = node.Height / 4;
            }
            else if (node.Type == NodeType.Circle)
            {
                handleX = (node.Width / 2) * 0.707106;
                handleY = (node.Height / 2) * 0.707106;
            }
            else if (node.Type == NodeType.Hexagon)
            {
                handleX = node.Width / 3;
                handleY = node.Height / 3;
            }

            <g transform="translate(@node.X, @node.Y)"
               @onmousedown="@(e => OnNodeMouseDown(e, node))"
               @onmouseup="@(e => OnNodeMouseUp(e, node))"
               @ontouchstart="@(e => OnNodeTouchStart(e, node))"
               @ontouchstart:stopPropagation="true"
               @ontouchend="@(e => OnNodeTouchEnd(e, node))"
               @ontouchend:stopPropagation="true"
               @ondblclick="@(() => EditNode(node))"
               @oncontextmenu="@(e => OnNodeContextMenu(e, node))"
               @oncontextmenu:preventDefault="true"
               @oncontextmenu:stopPropagation="true"
               class="graph-node" style="cursor: grab;">

                @if (node.Type == NodeType.Rectangle || node.Type == NodeType.RoundedRectangle || node.Type == NodeType.Stadium)
                {
                    double rx = node.Type == NodeType.Rectangle ? 0 : node.Type == NodeType.RoundedRectangle ? 10 : node.Height / 2;
                    <rect x="@(-node.Width/2)" y="@(-node.Height/2)" width="@node.Width" height="@node.Height" rx="@rx" ry="@rx"
                          fill="@(node == activeSourceNode ? "var(--mud-palette-primary-lighten)" : "var(--mud-palette-surface)")"
                          stroke="@(isSelectedNode ? "var(--mud-palette-primary)" : "var(--mud-palette-text-primary)")" stroke-width="@(isSelectedNode ? "4" : "2")" filter="url(#wobbly)" />
                }
                else if (node.Type == NodeType.Cylinder)
                {
                    <path d="M @(-node.Width/2) @(-node.Height/2 + 10) C @(-node.Width/2) @(-node.Height/2 - 10), @(node.Width/2) @(-node.Height/2 - 10), @(node.Width/2) @(-node.Height/2 + 10) L @(node.Width/2) @(node.Height/2 - 10) C @(node.Width/2) @(node.Height/2 + 10), @(-node.Width/2) @(node.Height/2 + 10), @(-node.Width/2) @(node.Height/2 - 10) Z M @(-node.Width/2) @(-node.Height/2 + 10) C @(-node.Width/2) @(-node.Height/2 + 30), @(node.Width/2) @(-node.Height/2 + 30), @(node.Width/2) @(-node.Height/2 + 10)"
                          fill="@(node == activeSourceNode ? "var(--mud-palette-primary-lighten)" : "var(--mud-palette-surface)")"
                          stroke="@(isSelectedNode ? "var(--mud-palette-primary)" : "var(--mud-palette-text-primary)")" stroke-width="@(isSelectedNode ? "4" : "2")" filter="url(#wobbly)" />
                }
                else if (node.Type == NodeType.Circle)
                {
                    <ellipse cx="0" cy="0" rx="@(node.Width/2)" ry="@(node.Height/2)"
                             fill="@(node == activeSourceNode ? "var(--mud-palette-primary-lighten)" : "var(--mud-palette-surface)")"
                             stroke="@(isSelectedNode ? "var(--mud-palette-primary)" : "var(--mud-palette-text-primary)")" stroke-width="@(isSelectedNode ? "4" : "2")" filter="url(#wobbly)" />
                }
                else if (node.Type == NodeType.Rhombus || node.Type == NodeType.Hexagon)
                {
                    string points = node.Type == NodeType.Rhombus ? $"0,{-node.Height/2} {node.Width/2},0 0,{node.Height/2} {-node.Width/2},0" : $"{node.Width/4},{-node.Height/2} {node.Width/2},0 {node.Width/4},{node.Height/2} {-node.Width/4},{node.Height/2} {-node.Width/2},0 {-node.Width/4},{-node.Height/2}";
                    <polygon points="@points"
                             fill="@(node == activeSourceNode ? "var(--mud-palette-primary-lighten)" : "var(--mud-palette-surface)")"
                             stroke="@(isSelectedNode ? "var(--mud-palette-primary)" : "var(--mud-palette-text-primary)")" stroke-width="@(isSelectedNode ? "4" : "2")" filter="url(#wobbly)" />
                }

                @if (editingNodeId != node.Id)
                {
                    <svg:text text-anchor="middle" dy="@(node.Type == NodeType.Cylinder ? "1em" : ".3em")" class="sketch-font" font-size="20" fill="var(--mud-palette-text-primary)" style="pointer-events: none;">@node.Label</svg:text>
                }
                else
                {
                    <foreignObject x="-55" y="@(node.Type == NodeType.Cylinder ? -10 : -20)" width="110" height="40" @onmousedown:stopPropagation="true" @ondblclick:stopPropagation="true">
                        <div xmlns="http://www.w3.org/1999/xhtml" style="width: 100%; height: 100%;">
                            <input id="node-editor-@node.Id"
                                   type="text"
                                   class="inline-editor-input"
                                   @bind="editingNodeText"
                                   @bind:event="oninput"
                                   @onblur="CommitNodeEdit"
                                   @onkeydown="OnEditorKeyDown" />
                        </div>
                    </foreignObject>
                }

                <!-- Resize Handle -->
                <polygon points="@(handleX - 10),@(handleY) @(handleX),@(handleY - 10) @(handleX),@(handleY)"
                         fill="var(--mud-palette-text-primary)" style="cursor: nwse-resize;"
                         @onmousedown="@(e => OnResizeMouseDown(e, node))" @onmousedown:stopPropagation="true"
                         @ontouchstart="@(e => OnResizeTouchStart(e, node))" @ontouchstart:stopPropagation="true" />
            </g>
        }

        <defs>
            <!-- Hand-drawn style arrowhead (stroke instead of filled polygon) -->
            <marker id="arrowhead" markerWidth="10" markerHeight="10" refX="9" refY="5" orient="auto">
                <path d="M 0 0 L 10 5 L 0 10 M 10 5 L 4 5" stroke="var(--mud-palette-text-primary)" stroke-width="2" fill="none" stroke-linejoin="round" stroke-linecap="round" />
            </marker>
            <marker id="arrowhead-selected" markerWidth="10" markerHeight="10" refX="9" refY="5" orient="auto">
                <path d="M 0 0 L 10 5 L 0 10 M 10 5 L 4 5" stroke="var(--mud-palette-primary)" stroke-width="2" fill="none" stroke-linejoin="round" stroke-linecap="round" />
            </marker>
            <filter id="wobbly" x="-10%" y="-10%" width="120%" height="120%">
                <feTurbulence type="fractalNoise" baseFrequency="0.04" numOctaves="2" result="noise" />
