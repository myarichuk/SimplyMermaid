    private async Task OnMouseUp(MouseEventArgs e)
    {
        await HandlePointerUp();
    }

    private async Task HandlePointerUp()
    {
        if (isPanning) isPanning = false;

        if (isLassoing)
        {
            isLassoing = false;
            double minX = Math.Min(lassoStartX, lassoCurrentX);
            double maxX = Math.Max(lassoStartX, lassoCurrentX);
            double minY = Math.Min(lassoStartY, lassoCurrentY);
            double maxY = Math.Max(lassoStartY, lassoCurrentY);

            foreach (var node in graph.Nodes)
            {
                // Simple point check for selection (or bounding box if desired)
                if (node.X >= minX && node.X <= maxX && node.Y >= minY && node.Y <= maxY)
                {
                    selectedNodes.Add(node);
                }
            }

            foreach (var edge in graph.Edges)
            {
                var sourceNode = graph.Nodes.FirstOrDefault(n => n.Id == edge.SourceNodeId);
                var targetNode = graph.Nodes.FirstOrDefault(n => n.Id == edge.TargetNodeId);
                if (sourceNode != null && targetNode != null)
                {
                    if (sourceNode.X >= minX && sourceNode.X <= maxX && sourceNode.Y >= minY && sourceNode.Y <= maxY &&
                        targetNode.X >= minX && targetNode.X <= maxX && targetNode.Y >= minY && targetNode.Y <= maxY)
                    {
                        selectedEdges.Add(edge);
                    }
                }
            }
            await UpdateMermaidPreviewAsync();
        }

        if (resizingNode != null)
        {
            resizingNode = null;
            await UpdateMermaidPreviewAsync();
        }

        if (draggingNode != null)
        {
            draggingNode = null;
            await UpdateMermaidPreviewAsync();
        }

        if (isConnecting)
        {
            isConnecting = false;
            activeSourceNode = null;
        }
    }

    // Fix for Issue 3: STATE SYNC RACES
    // Before: Multiple awaited UpdateMermaidPreviewAsync calls caused C#/JS/Mermaid drift during rapid edits.
    // After: Centralized RenderQueue enforces a single sequential update loop.
    private bool _isRendering = false;
    private bool _renderPending = false;
    private Task? _currentRenderTask = null;

    private Task QueueRender(bool immediate = false)
    {
        _renderPending = true;

        if (_isRendering)
        {
            // If we are already rendering, and this is an immediate request, we can just await the ongoing loop
            // to pick up our pending request.
            return immediate ? _currentRenderTask ?? Task.CompletedTask : Task.CompletedTask;
        }

        _currentRenderTask = ProcessRenderQueueAsync();
        return immediate ? _currentRenderTask : Task.CompletedTask;
    }

    private async Task ProcessRenderQueueAsync()
    {
        while (_renderPending)
        {
            _renderPending = false;
            _isRendering = true;
            try
            {
                mermaidCode = MermaidSerializer.Serialize(graph);
                mermaidImportCode = mermaidCode;
                await MermaidInterop.RenderMermaidAsync("mermaid-preview", mermaidCode);
                await LocalStorage.SetItemAsync("mermaid_graph", graph);
            }
            finally
            {
                _isRendering = false;
            }
        }
        _currentRenderTask = null;
    }

    private async Task UpdateMermaidPreviewAsync()
    {
        await QueueRender(true);
    }

    private async Task ImportMermaidAsync()
    {
        if (string.IsNullOrWhiteSpace(mermaidImportCode)) return;

        try
        {
            var lines = mermaidImportCode.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);
            var newGraph = new Graph();
            var nodesMap = new Dictionary<string, Node>();
            Dictionary<string, double[]> positions = null;

            // Temporary simple parsing
            var nodeRegex = new System.Text.RegularExpressions.Regex(@"^\s*([A-Za-z0-9_-]+)(?:\[|\(|\{)(.*?)(?:\]|\)|\})");
            var edgeRegex = new System.Text.RegularExpressions.Regex(@"^\s*([A-Za-z0-9_-]+)\s*-+>?\s*(?:\|(.*?)\|)?\s*([A-Za-z0-9_-]+)");

            foreach (var line in lines)
            {
                if (line.StartsWith("%% SimplyMermaidPositions:"))
                {
                    var jsonStr = line.Substring("%% SimplyMermaidPositions:".Length).Trim();
                    positions = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, double[]>>(jsonStr);
                    continue;
                }

                // Process edges first because they might not have explicitly defined nodes in basic Mermaid
                var edgeMatch = edgeRegex.Match(line);
                if (edgeMatch.Success)
                {
                    var sourceId = edgeMatch.Groups[1].Value;
                    var label = edgeMatch.Groups[2].Value.Replace("&quot;", "\"").Replace("<br/>", "\n").Replace("&lt;", "<").Replace("&gt;", ">").Replace("#35;", "#").Replace("#58;", ":").Replace("#59;", ";").Trim('"');
                    var targetId = edgeMatch.Groups[3].Value;

                    newGraph.Edges.Add(new MermaidEditor.Models.Edge
                    {
                        Id = Guid.NewGuid().ToString(),
                        SourceNodeId = sourceId,
                        TargetNodeId = targetId,
                        Label = string.IsNullOrWhiteSpace(label) ? "" : label,
                        LineStyle = line.Contains("-.-") ? EdgeLineStyle.Dashed : EdgeLineStyle.Solid // Simplify for now
                    });

                    if (!nodesMap.ContainsKey(sourceId)) nodesMap[sourceId] = new Node { Id = sourceId, Label = sourceId };
                    if (!nodesMap.ContainsKey(targetId)) nodesMap[targetId] = new Node { Id = targetId, Label = targetId };
                    continue;
                }

                var nodeMatch = nodeRegex.Match(line);
                if (nodeMatch.Success)
                {
                    var nodeId = nodeMatch.Groups[1].Value;
                    var label = nodeMatch.Groups[2].Value.Replace("&quot;", "\"").Replace("<br/>", "\n").Replace("&lt;", "<").Replace("&gt;", ">").Replace("#35;", "#").Replace("#58;", ":").Replace("#59;", ";").Trim('"');

                    NodeType type = NodeType.Rectangle;
                    if (line.Contains($"(({nodeMatch.Groups[2].Value}))")) type = NodeType.Circle;
                    else if (line.Contains($"([{nodeMatch.Groups[2].Value}])")) type = NodeType.Stadium;
                    else if (line.Contains($"[({nodeMatch.Groups[2].Value})]")) type = NodeType.Cylinder;
                    else if (line.Contains($"({nodeMatch.Groups[2].Value})")) type = NodeType.RoundedRectangle;
                    else if (line.Contains($"{{{{{nodeMatch.Groups[2].Value}}}}}")) type = NodeType.Hexagon;
                    else if (line.Contains($"{{{nodeMatch.Groups[2].Value}}}")) type = NodeType.Rhombus;

                    if (nodesMap.TryGetValue(nodeId, out var existingNode))
                    {
                        existingNode.Label = label;
                        existingNode.Type = type;
                        if (type == NodeType.Circle) { existingNode.Width = 80; existingNode.Height = 80; }
                    }
                    else
                    {
                        nodesMap[nodeId] = new Node
                        {
                            Id = nodeId,
                            Label = label,
                            Type = type,
                            Width = type == NodeType.Circle ? 80 : 120,
                            Height = type == NodeType.Circle ? 80 : 60
                        };
                    }
                }
            }

            // Restore precise positions if available
            int xOffset = 0;
            int yOffset = 0;
            foreach (var kvp in nodesMap)
            {
                var node = kvp.Value;
                if (positions != null && positions.TryGetValue(node.Id, out var pos))
                {
                    node.X = pos[0];
                    node.Y = pos[1];
                }
                else
                {
                    // Fallback positioning if no comment
                    node.X = 100 + xOffset;
                    node.Y = 100 + yOffset;
                    xOffset += 150;
                    if (xOffset > 600) { xOffset = 0; yOffset += 100; }
                }
                newGraph.Nodes.Add(node);
            }

            if (newGraph.Nodes.Any())
            {
                CaptureState();
                graph = newGraph;
                selectedNode = null;
                selectedEdge = null;
                selectedNodes.Clear();
                await UpdateMermaidPreviewAsync();
                CommitState();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Import failed: {ex.Message}");
        }
    }
