    }

    private async Task DeleteNode(Node node)
    {
        CaptureState();
        graph.Nodes.Remove(node);
        graph.Edges.RemoveAll(e => e.SourceNodeId == node.Id || e.TargetNodeId == node.Id);
        selectedNode = null;
        await UpdateMermaidPreviewAsync();
        CommitState();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if ((e.CtrlKey || e.MetaKey) && (e.Key == "a" || e.Key == "A"))
        {
            selectedNodes = new HashSet<Node>(graph.Nodes);
            selectedEdges = new HashSet<MermaidEditor.Models.Edge>(graph.Edges);
            await UpdateMermaidPreviewAsync();
            return;
        }

        if (e.Key == "Escape")
        {
            selectedNode = null;
            selectedEdge = null;
            selectedNodes.Clear();
            selectedEdges.Clear();
            StateHasChanged();
            return;
        }

        if ((e.CtrlKey || e.MetaKey) && (e.Key == "z" || e.Key == "Z"))
        {
            if (e.ShiftKey)
            {
                Redo();
            }
            else
            {
                Undo();
            }
            return;
        }

        if ((e.CtrlKey || e.MetaKey) && (e.Key == "y" || e.Key == "Y"))
        {
            Redo();
            return;
        }

        if (e.Key == "Delete" || e.Key == "Backspace")
        {
            bool updated = false;
            if (selectedNodes.Count > 0 && editingNodeId == null)
            {
                CaptureState();
                foreach (var node in selectedNodes.ToList())
                {
                    graph.Nodes.Remove(node);
                    graph.Edges.RemoveAll(ed => ed.SourceNodeId == node.Id || ed.TargetNodeId == node.Id);
                }
                selectedNodes.Clear();
                selectedNode = null;
                updated = true;
            }
            else if (selectedNode != null && editingNodeId == null)
            {
                CaptureState();
                graph.Nodes.Remove(selectedNode);
                graph.Edges.RemoveAll(ed => ed.SourceNodeId == selectedNode.Id || ed.TargetNodeId == selectedNode.Id);
                selectedNode = null;
                updated = true;
            }

            if (selectedEdges.Count > 0 && editingEdgeId == null)
            {
                if (!updated) CaptureState();
                foreach (var edge in selectedEdges.ToList())
                {
                    graph.Edges.Remove(edge);
                }
                selectedEdges.Clear();
                selectedEdge = null;
                updated = true;
            }
            else if (selectedEdge != null && editingEdgeId == null)
            {
                if (!updated) CaptureState();
                graph.Edges.Remove(selectedEdge);
                selectedEdge = null;
                updated = true;
            }

            if (updated)
            {
                await UpdateMermaidPreviewAsync();
                CommitState();
            }
        }
    }

