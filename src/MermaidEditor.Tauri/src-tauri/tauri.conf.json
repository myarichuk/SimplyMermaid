{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Simply Mermaid",
  "version": "0.1.0",
  "identifier": "com.mermaideditor.tauri",
  "build": {
    "frontendDist": "../../MermaidEditor/bin/Release/net10.0/publish/wwwroot",
    "beforeBuildCommand": "dotnet publish ../MermaidEditor/MermaidEditor.csproj -c Release",
    "beforeDevCommand": "dotnet run --project ../MermaidEditor/MermaidEditor.csproj",
    "devUrl": "http://localhost:5165"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Simply Mermaid",
        "width": 800,
        "height": 600,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
